      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n\n  :root {\n    --bg-main: #020617;\n    --card-bg: rgba(15, 23, 42, 0.6);\n    --cyan-accent: #06b6d4;\n    --emerald-accent: #10b981;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: var(--bg-main);\n    color: #f8fafc;\n    margin: 0;\n  }\n\n  .radar-grid {\n    background-image: radial-gradient(circle at 1px 1px, rgba(34, 211, 238, 0.05) 1px, transparent 0);\n    background-size: 24px 24px;\n  }\n\n  .glass-card {\n    background: rgba(15, 23, 42, 0.4);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(34, 211, 238, 0.15);\n  }\n\n  .hero-gradient-overlay {\n    background: linear-gradient(to right, #020617 0%, rgba(2, 6, 23, 0.8) 40%, rgba(2, 6, 23, 0.2) 100%);\n  }\n\n  .hero-bottom-gradient {\n    background: linear-gradient(to top, #020617 0%, transparent 100%);\n  }\n</style>\n\n<main class=\"min-h-screen relative overflow-hidden radar-grid\" data-kid=\"1\">\n  \n  <section class=\"relative min-h-[92vh] flex items-center overflow-hidden\" data-kid=\"2\">\n    <div class=\"absolute inset-0\" data-kid=\"3\">\n      <img src=\"/api/local/images/frontend/public/images/bharat-climate-hero.png\" alt=\"Satellite India\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"4\">\n      <div class=\"absolute inset-0 hero-gradient-overlay\" data-kid=\"5\"></div>\n      <div class=\"absolute inset-0 hero-bottom-gradient\" data-kid=\"6\"></div>\n    </div>\n\n    <div class=\"relative z-10 container mx-auto px-6 lg:px-16 pt-24\" data-kid=\"7\">\n      <div class=\"max-w-3xl\" data-kid=\"8\">\n        <div class=\"inline-flex items-center gap-2 rounded-md border border-cyan-400/30 bg-cyan-400/10 px-3 py-1.5 text-sm font-medium text-cyan-200 backdrop-blur-sm\" data-kid=\"9\">\n          <i data-lucide=\"shield-alert\" class=\"w-4 h-4\" data-kid=\"10\"></i>\n          Government-tech climate command layer\n        </div>\n        \n        <h1 class=\"mt-8 text-6xl lg:text-8xl font-bold tracking-tight text-white\" data-kid=\"11\">\n          Bharat Climate Twin\n        </h1>\n        \n        <p class=\"mt-8 text-xl text-slate-300 leading-relaxed max-w-2xl\" data-kid=\"12\">\n          An AI-powered digital twin of India's climate system for prediction, simulation, and visualization of flood, drought, heat, water, air, and crop risks.\n        </p>\n\n        <div class=\"mt-12 flex flex-wrap gap-4\" data-kid=\"13\">\n          <a href=\"#\" class=\"inline-flex items-center gap-2 bg-cyan-500 hover:bg-cyan-600 text-slate-950 font-semibold px-8 py-4 rounded-lg transition-all shadow-[0_0_20px_rgba(6,182,212,0.3)]\" data-kid=\"14\">\n            Open Command Center\n            <i data-lucide=\"arrow-right\" class=\"w-5 h-5\" data-kid=\"15\"></i>\n          </a>\n          <a href=\"#\" class=\"inline-flex items-center gap-2 border border-slate-700 bg-slate-900/50 hover:bg-slate-800 text-white font-semibold px-8 py-4 rounded-lg transition-all backdrop-blur-md\" data-kid=\"16\">\n            <i data-lucide=\"map\" class=\"w-5 h-5 text-cyan-400\" data-kid=\"17\"></i>\n            Launch Digital Twin Map\n          </a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative z-20 -mt-20 container mx-auto px-6 lg:px-16 mb-24\" data-kid=\"18\">\n    <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4\" data-kid=\"19\">\n      <div class=\"glass-card p-6 rounded-xl hover:border-cyan-400/40 transition-colors group\" data-kid=\"20\">\n        <div class=\"w-12 h-12 rounded-lg bg-cyan-400/10 flex items-center justify-center text-cyan-400 border border-cyan-400/20 group-hover:bg-cyan-400/20 transition-all\" data-kid=\"21\">\n          <i data-lucide=\"satellite\" class=\"w-6 h-6\" data-kid=\"22\"></i>\n        </div>\n        <h3 class=\"mt-6 text-lg font-semibold text-white\" data-kid=\"23\">Satellite + Weather Fusion</h3>\n        <p class=\"mt-3 text-sm text-slate-400 leading-relaxed\" data-kid=\"24\">Multi-source ingestion from INSAT, NRSC, Bhuvan, and IMD for high-resolution ground truth.</p>\n      </div>\n\n      <div class=\"glass-card p-6 rounded-xl hover:border-cyan-400/40 transition-colors group\" data-kid=\"25\">\n        <div class=\"w-12 h-12 rounded-lg bg-cyan-400/10 flex items-center justify-center text-cyan-400 border border-cyan-400/20 group-hover:bg-cyan-400/20 transition-all\" data-kid=\"26\">\n          <i data-lucide=\"gauge\" class=\"w-6 h-6\" data-kid=\"27\"></i>\n        </div>\n        <h3 class=\"mt-6 text-lg font-semibold text-white\" data-kid=\"28\">District Risk Engine</h3>\n        <p class=\"mt-3 text-sm text-slate-400 leading-relaxed\" data-kid=\"29\">Dynamic vulnerability scoring from 0-100 for flood, drought, heatwave, and water-stress.</p>\n      </div>\n\n      <div class=\"glass-card p-6 rounded-xl hover:border-cyan-400/40 transition-colors group\" data-kid=\"30\">\n        <div class=\"w-12 h-12 rounded-lg bg-cyan-400/10 flex items-center justify-center text-cyan-400 border border-cyan-400/20 group-hover:bg-cyan-400/20 transition-all\" data-kid=\"31\">\n          <i data-lucide=\"activity\" class=\"w-6 h-6\" data-kid=\"32\"></i>\n        </div>\n        <h3 class=\"mt-6 text-lg font-semibold text-white\" data-kid=\"33\">Scenario Simulator</h3>\n        <p class=\"mt-3 text-sm text-slate-400 leading-relaxed\" data-kid=\"34\">Stress-test climate variables to predict multi-sector outcomes and infrastructure resilience.</p>\n      </div>\n\n      <div class=\"glass-card p-6 rounded-xl hover:border-cyan-400/40 transition-colors group\" data-kid=\"35\">\n        <div class=\"w-12 h-12 rounded-lg bg-cyan-400/10 flex items-center justify-center text-cyan-400 border border-cyan-400/20 group-hover:bg-cyan-400/20 transition-all\" data-kid=\"36\">\n          <i data-lucide=\"zap\" class=\"w-6 h-6\" data-kid=\"37\"></i>\n        </div>\n        <h3 class=\"mt-6 text-lg font-semibold text-white\" data-kid=\"38\">AI Climate Copilot</h3>\n        <p class=\"mt-3 text-sm text-slate-400 leading-relaxed\" data-kid=\"39\">Conversational intelligence for operational command, generating instant reports and maps.</p>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"container mx-auto px-6 lg:px-16 py-24\" data-kid=\"40\">\n    <div class=\"max-w-4xl mb-16\" data-kid=\"41\">\n      <div class=\"inline-flex items-center gap-2 rounded-md border border-cyan-400/20 bg-cyan-400/10 px-3 py-1 text-sm font-medium text-cyan-400\" data-kid=\"42\">\n        <i data-lucide=\"database\" class=\"w-4 h-4\" data-kid=\"43\"></i>\n        National Climate Datasets\n      </div>\n      <h2 class=\"mt-6 text-4xl lg:text-5xl font-bold text-white\" data-kid=\"44\">Powered by India's Climate Data Infrastructure</h2>\n      <p class=\"mt-6 text-lg text-slate-400 max-w-2xl\" data-kid=\"45\">\n        Bharat Climate Twin integrates meteorological observations, satellite products, and national climate datasets to power AI-driven forecasting and risk assessment.\n      </p>\n    </div>\n\n    <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\" data-kid=\"46\">\n      \n      <div class=\"glass-card p-6 rounded-xl\" data-kid=\"47\">\n        <div class=\"flex justify-between items-start mb-6\" data-kid=\"48\">\n          <div class=\"w-12 h-12 rounded-lg bg-cyan-400/10 flex items-center justify-center text-cyan-400 border border-cyan-400/20\" data-kid=\"49\">\n            <i data-lucide=\"cloud-rain\" class=\"w-6 h-6\" data-kid=\"50\"></i>\n          </div>\n          <span class=\"px-2 py-1 rounded bg-emerald-400/10 text-emerald-400 text-xs font-medium border border-emerald-400/20\" data-kid=\"51\">0.25° × 0.25°</span>\n        </div>\n        <h4 class=\"text-white font-semibold\" data-kid=\"52\">IMD Gridded Rainfall</h4>\n        <p class=\"mt-3 text-sm text-slate-400 leading-relaxed\" data-kid=\"53\">High-resolution rainfall observations used for climate analysis and drought monitoring.</p>\n      </div>\n\n      \n      <div class=\"glass-card p-6 rounded-xl\" data-kid=\"54\">\n        <div class=\"flex justify-between items-start mb-6\" data-kid=\"55\">\n          <div class=\"w-12 h-12 rounded-lg bg-cyan-400/10 flex items-center justify-center text-cyan-400 border border-cyan-400/20\" data-kid=\"56\">\n            <i data-lucide=\"thermometer\" class=\"w-6 h-6\" data-kid=\"57\"></i>\n          </div>\n          <span class=\"px-2 py-1 rounded bg-emerald-400/10 text-emerald-400 text-xs font-medium border border-emerald-400/20\" data-kid=\"58\">1° × 1°</span>\n        </div>\n        <h4 class=\"text-white font-semibold\" data-kid=\"59\">IMD Maximum Temperature</h4>\n        <p class=\"mt-3 text-sm text-slate-400 leading-relaxed\" data-kid=\"60\">Daily maximum temperature dataset supporting heatwave and climate trend analysis.</p>\n      </div>\n\n      \n      <div class=\"glass-card p-6 rounded-xl\" data-kid=\"61\">\n        <div class=\"flex justify-between items-start mb-6\" data-kid=\"62\">\n          <div class=\"w-12 h-12 rounded-lg bg-cyan-400/10 flex items-center justify-center text-cyan-400 border border-cyan-400/20\" data-kid=\"63\">\n            <i data-lucide=\"satellite\" class=\"w-6 h-6\" data-kid=\"64\"></i>\n          </div>\n          <span class=\"px-2 py-1 rounded bg-emerald-400/10 text-emerald-400 text-xs font-medium border border-emerald-400/20\" data-kid=\"65\">Satellite Product</span>\n        </div>\n        <h4 class=\"text-white font-semibold\" data-kid=\"66\">INSAT Land Surface Temp</h4>\n        <p class=\"mt-3 text-sm text-slate-400 leading-relaxed\" data-kid=\"67\">Surface temperature observations derived from INSAT Earth observation missions.</p>\n      </div>\n    </div>\n\n    \n    <div class=\"mt-12 glass-card p-8 rounded-2xl bg-slate-950/20\" data-kid=\"68\">\n      <h3 class=\"text-xl font-semibold text-white mb-8\" data-kid=\"69\">Climate Data Fusion Pipeline</h3>\n      <div class=\"flex flex-wrap items-center gap-4\" data-kid=\"70\">\n        <div class=\"px-4 py-2 rounded-lg border border-cyan-400/20 bg-cyan-400/5 text-cyan-200 text-sm\" data-kid=\"71\">IMD Rainfall</div>\n        <i data-lucide=\"chevron-right\" class=\"w-4 h-4 text-slate-600\" data-kid=\"72\"></i>\n        <div class=\"px-4 py-2 rounded-lg border border-cyan-400/20 bg-cyan-400/5 text-cyan-200 text-sm\" data-kid=\"73\">IMD Temperature</div>\n        <i data-lucide=\"chevron-right\" class=\"w-4 h-4 text-slate-600\" data-kid=\"74\"></i>\n        <div class=\"px-4 py-2 rounded-lg border border-cyan-400/20 bg-cyan-400/5 text-cyan-200 text-sm\" data-kid=\"75\">INSAT Products</div>\n        <i data-lucide=\"chevron-right\" class=\"w-4 h-4 text-slate-600\" data-kid=\"76\"></i>\n        <div class=\"px-4 py-2 rounded-lg border border-cyan-400/20 bg-cyan-400/5 text-cyan-200 text-sm\" data-kid=\"77\">AI Forecast Engine</div>\n        <i data-lucide=\"chevron-right\" class=\"w-4 h-4 text-slate-600\" data-kid=\"78\"></i>\n        <div class=\"px-4 py-2 rounded-lg border border-emerald-400/30 bg-emerald-400/10 text-emerald-300 font-semibold text-sm\" data-kid=\"79\">Climate Twin</div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"container mx-auto px-6 lg:px-16 pb-32\" data-kid=\"80\">\n    <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-6\" data-kid=\"81\">\n      <div class=\"p-8 rounded-2xl border border-cyan-400/10 bg-slate-950/30 flex flex-col gap-4\" data-kid=\"82\">\n        <i data-lucide=\"droplets\" class=\"w-8 h-8 text-emerald-300\" data-kid=\"83\"></i>\n        <h4 class=\"text-xl font-bold text-white\" data-kid=\"84\">Flood Risk</h4>\n        <p class=\"text-slate-400 text-sm\" data-kid=\"85\">Brahmaputra, coastal, and urban drainage exposure monitoring and early warning.</p>\n      </div>\n      <div class=\"p-8 rounded-2xl border border-cyan-400/10 bg-slate-950/30 flex flex-col gap-4\" data-kid=\"86\">\n        <i data-lucide=\"bar-chart-3\" class=\"w-8 h-8 text-emerald-300\" data-kid=\"87\"></i>\n        <h4 class=\"text-xl font-bold text-white\" data-kid=\"88\">Drought Watch</h4>\n        <p class=\"text-slate-400 text-sm\" data-kid=\"89\">Rainfall deficit, vegetation health, and reservoir drawdown analytics for food security.</p>\n      </div>\n      <div class=\"p-8 rounded-2xl border border-cyan-400/10 bg-slate-950/30 flex flex-col gap-4\" data-kid=\"90\">\n        <i data-lucide=\"shield-check\" class=\"w-8 h-8 text-emerald-300\" data-kid=\"91\"></i>\n        <h4 class=\"text-xl font-bold text-white\" data-kid=\"92\">Action Layer</h4>\n        <p class=\"text-slate-400 text-sm\" data-kid=\"93\">District rankings, localized alerts, and role-based access for response operations.</p>\n      </div>\n    </div>\n  </section>\n</main>\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"94\"></script>\n<script data-kid=\"95\">\n  lucide.createIcons();\n</script>",
