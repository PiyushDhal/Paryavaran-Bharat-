      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n\n  :root {\n    --bg-main: #020617;\n    --card-bg: rgba(15, 23, 42, 0.6);\n    --cyan-accent: #06b6d4;\n    --emerald-accent: #10b981;\n    --rose-accent: #f43f5e;\n    --amber-accent: #f59e0b;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: var(--bg-main);\n    color: #f8fafc;\n    margin: 0;\n  }\n\n  .radar-grid {\n    background-image: radial-gradient(circle at 1px 1px, rgba(34, 211, 238, 0.05) 1px, transparent 0);\n    background-size: 24px 24px;\n  }\n\n  .glass-card {\n    background: rgba(15, 23, 42, 0.4);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(34, 211, 238, 0.15);\n  }\n\n  .glow-rose {\n    box-shadow: 0 0 20px rgba(244, 63, 94, 0.15);\n  }\n\n  .glow-cyan {\n    box-shadow: 0 0 20px rgba(6, 182, 212, 0.15);\n  }\n</style>\n\n<main class=\"min-h-screen relative radar-grid p-8 lg:p-16\" data-kid=\"1\">\n  \n  <header class=\"max-w-7xl mx-auto mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6\" data-kid=\"2\">\n    <div data-kid=\"3\">\n      <div class=\"inline-flex items-center gap-2 rounded-md border border-rose-500/30 bg-rose-500/10 px-3 py-1.5 text-sm font-medium text-rose-300 backdrop-blur-sm mb-4\" data-kid=\"4\">\n        <i data-lucide=\"shield-alert\" class=\"w-4 h-4 text-rose-400\" data-kid=\"5\"></i>\n        3 Critical Alerts Active\n      </div>\n      <h1 class=\"text-4xl lg:text-5xl font-bold tracking-tight text-white\" data-kid=\"6\">Climate Alert Command</h1>\n      <p class=\"mt-4 text-slate-400 max-w-2xl text-lg\" data-kid=\"7\">\n        Centralized monitoring and early warning dispatch for national climate hazards. Prioritized by severity and district vulnerability.\n      </p>\n    </div>\n    <div class=\"flex gap-3\" data-kid=\"8\">\n      <button class=\"glass-card px-4 py-2 rounded-lg text-sm font-medium hover:bg-slate-800 transition-colors flex items-center gap-2\" data-kid=\"9\">\n        <i data-lucide=\"filter\" class=\"w-4 h-4 text-cyan-400\" data-kid=\"10\"></i>\n        Filter Hazards\n      </button>\n      <button class=\"glass-card px-4 py-2 rounded-lg text-sm font-medium hover:bg-slate-800 transition-colors flex items-center gap-2 text-rose-300 border-rose-500/20\" data-kid=\"11\">\n        <i data-lucide=\"alert-octagon\" class=\"w-4 h-4\" data-kid=\"12\"></i>\n        Critical Only\n      </button>\n    </div>\n  </header>\n\n  <div class=\"max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-8\" data-kid=\"13\">\n    \n    <div class=\"lg:col-span-2 space-y-6\" data-kid=\"14\">\n      \n      <div class=\"glass-card rounded-2xl overflow-hidden border-rose-500/20 glow-rose relative group\" data-kid=\"15\">\n        <div class=\"absolute left-0 top-0 bottom-0 w-1 bg-rose-500\" data-kid=\"16\"></div>\n        <div class=\"p-6\" data-kid=\"17\">\n          <div class=\"flex flex-wrap items-center justify-between gap-4 mb-6\" data-kid=\"18\">\n            <div class=\"flex items-center gap-3\" data-kid=\"19\">\n              <div class=\"w-12 h-12 rounded-lg bg-rose-500/10 flex items-center justify-center text-rose-500 border border-rose-500/20\" data-kid=\"20\">\n                <i data-lucide=\"waves\" class=\"w-6 h-6\" data-kid=\"21\"></i>\n              </div>\n              <div data-kid=\"22\">\n                <span class=\"text-xs uppercase tracking-widest text-rose-400 font-bold\" data-kid=\"23\">Flood Risk</span>\n                <h3 class=\"text-xl font-bold text-white\" data-kid=\"24\">Brahmaputra Flash Flood Warning</h3>\n              </div>\n            </div>\n            <div class=\"flex items-center gap-3\" data-kid=\"25\">\n              <span class=\"px-3 py-1 rounded-full bg-rose-500/20 text-rose-400 text-xs font-bold border border-rose-500/30\" data-kid=\"26\">CRITICAL</span>\n              <span class=\"text-slate-500 text-xs\" data-kid=\"27\">2 mins ago</span>\n            </div>\n          </div>\n          <div class=\"grid grid-cols-2 md:grid-cols-4 gap-4 mb-6\" data-kid=\"28\">\n            <div class=\"p-3 rounded-xl bg-slate-900/40 border border-white/5\" data-kid=\"29\">\n              <span class=\"text-[10px] text-slate-500 uppercase tracking-tight\" data-kid=\"30\">District</span>\n              <p class=\"text-sm font-semibold text-white\" data-kid=\"31\">Dhubri, Assam</p>\n            </div>\n            <div class=\"p-3 rounded-xl bg-slate-900/40 border border-white/5\" data-kid=\"32\">\n              <span class=\"text-[10px] text-slate-500 uppercase tracking-tight\" data-kid=\"33\">Vulnerability</span>\n              <p class=\"text-sm font-semibold text-rose-400\" data-kid=\"34\">High (92/100)</p>\n            </div>\n            <div class=\"p-3 rounded-xl bg-slate-900/40 border border-white/5\" data-kid=\"35\">\n              <span class=\"text-[10px] text-slate-500 uppercase tracking-tight\" data-kid=\"36\">Expected Peak</span>\n              <p class=\"text-sm font-semibold text-white\" data-kid=\"37\">+1.2m Elevation</p>\n            </div>\n            <div class=\"p-3 rounded-xl bg-slate-900/40 border border-white/5\" data-kid=\"38\">\n              <span class=\"text-[10px] text-slate-500 uppercase tracking-tight\" data-kid=\"39\">Population at Risk</span>\n              <p class=\"text-sm font-semibold text-white\" data-kid=\"40\">245,000</p>\n            </div>\n          </div>\n          <p class=\"text-slate-400 text-sm leading-relaxed mb-6\" data-kid=\"41\">\n            Rapid water level rise detected at Gauge Station ID: BH-72. Discharge rate exceeding safety thresholds. Immediate evacuation of low-lying floodplains advised.\n          </p>\n          <div class=\"flex gap-3\" data-kid=\"42\">\n            <button class=\"flex-1 bg-rose-500 hover:bg-rose-600 text-slate-950 font-bold py-3 rounded-lg transition-all text-sm flex items-center justify-center gap-2\" data-kid=\"43\">\n              <i data-lucide=\"radio\" class=\"w-4 h-4\" data-kid=\"44\"></i>\n              Dispatch Alert\n            </button>\n            <button class=\"px-6 py-3 rounded-lg border border-slate-700 hover:bg-slate-800 transition-all text-sm font-medium\" data-kid=\"45\">\n              Open Map\n            </button>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"glass-card rounded-2xl overflow-hidden border-amber-500/20 relative group\" data-kid=\"46\">\n        <div class=\"absolute left-0 top-0 bottom-0 w-1 bg-amber-500\" data-kid=\"47\"></div>\n        <div class=\"p-6\" data-kid=\"48\">\n          <div class=\"flex flex-wrap items-center justify-between gap-4 mb-6\" data-kid=\"49\">\n            <div class=\"flex items-center gap-3\" data-kid=\"50\">\n              <div class=\"w-12 h-12 rounded-lg bg-amber-500/10 flex items-center justify-center text-amber-500 border border-amber-500/20\" data-kid=\"51\">\n                <i data-lucide=\"flame\" class=\"w-6 h-6\" data-kid=\"52\"></i>\n              </div>\n              <div data-kid=\"53\">\n                <span class=\"text-xs uppercase tracking-widest text-amber-400 font-bold\" data-kid=\"54\">Heatwave</span>\n                <h3 class=\"text-xl font-bold text-white\" data-kid=\"55\">Loo Wind & Extreme Heat Surge</h3>\n              </div>\n            </div>\n            <div class=\"flex items-center gap-3\" data-kid=\"56\">\n              <span class=\"px-3 py-1 rounded-full bg-amber-500/20 text-amber-400 text-xs font-bold border border-amber-500/30\" data-kid=\"57\">HIGH</span>\n              <span class=\"text-slate-500 text-xs\" data-kid=\"58\">45 mins ago</span>\n            </div>\n          </div>\n          <div class=\"grid grid-cols-2 md:grid-cols-4 gap-4 mb-6\" data-kid=\"59\">\n            <div class=\"p-3 rounded-xl bg-slate-900/40 border border-white/5\" data-kid=\"60\">\n              <span class=\"text-[10px] text-slate-500 uppercase tracking-tight\" data-kid=\"61\">District</span>\n              <p class=\"text-sm font-semibold text-white\" data-kid=\"62\">Churu, Rajasthan</p>\n            </div>\n            <div class=\"p-3 rounded-xl bg-slate-900/40 border border-white/5\" data-kid=\"63\">\n              <span class=\"text-[10px] text-slate-500 uppercase tracking-tight\" data-kid=\"64\">Temperature</span>\n              <p class=\"text-sm font-semibold text-amber-400\" data-kid=\"65\">48.2°C</p>\n            </div>\n            <div class=\"p-3 rounded-xl bg-slate-900/40 border border-white/5\" data-kid=\"66\">\n              <span class=\"text-[10px] text-slate-500 uppercase tracking-tight\" data-kid=\"67\">Duration</span>\n              <p class=\"text-sm font-semibold text-white\" data-kid=\"68\">72h Forecast</p>\n            </div>\n            <div class=\"p-3 rounded-xl bg-slate-900/40 border border-white/5\" data-kid=\"69\">\n              <span class=\"text-[10px] text-slate-500 uppercase tracking-tight\" data-kid=\"70\">Sector Alert</span>\n              <p class=\"text-sm font-semibold text-white\" data-kid=\"71\">Agri/Health</p>\n            </div>\n          </div>\n          <p class=\"text-slate-400 text-sm leading-relaxed mb-6\" data-kid=\"72\">\n            Severe heatwave conditions persisting. Soil moisture depletion rate at critical levels. Health advisory issued for elderly and outdoor labor.\n          </p>\n          <div class=\"flex gap-3\" data-kid=\"73\">\n            <button class=\"flex-1 border border-amber-500/30 bg-amber-500/10 hover:bg-amber-500/20 text-amber-300 font-bold py-3 rounded-lg transition-all text-sm\" data-kid=\"74\">\n              Deploy Mitigation Measures\n            </button>\n            <button class=\"px-6 py-3 rounded-lg border border-slate-700 hover:bg-slate-800 transition-all text-sm font-medium text-slate-300\" data-kid=\"75\">\n              Details\n            </button>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"glass-card rounded-2xl overflow-hidden border-cyan-500/20 relative group\" data-kid=\"76\">\n        <div class=\"absolute left-0 top-0 bottom-0 w-1 bg-cyan-500\" data-kid=\"77\"></div>\n        <div class=\"p-6\" data-kid=\"78\">\n          <div class=\"flex flex-wrap items-center justify-between gap-4 mb-6\" data-kid=\"79\">\n            <div class=\"flex items-center gap-3\" data-kid=\"80\">\n              <div class=\"w-12 h-12 rounded-lg bg-cyan-400/10 flex items-center justify-center text-cyan-400 border border-cyan-400/20\" data-kid=\"81\">\n                <i data-lucide=\"cloud-off\" class=\"w-6 h-6\" data-kid=\"82\"></i>\n              </div>\n              <div data-kid=\"83\">\n                <span class=\"text-xs uppercase tracking-widest text-cyan-400 font-bold\" data-kid=\"84\">Drought Watch</span>\n                <h3 class=\"text-xl font-bold text-white\" data-kid=\"85\">Rainfall Deficit Anomaly</h3>\n              </div>\n            </div>\n            <div class=\"flex items-center gap-3\" data-kid=\"86\">\n              <span class=\"px-3 py-1 rounded-full bg-cyan-500/20 text-cyan-400 text-xs font-bold border border-cyan-500/30\" data-kid=\"87\">MODERATE</span>\n              <span class=\"text-slate-500 text-xs\" data-kid=\"88\">3 hours ago</span>\n            </div>\n          </div>\n          <div class=\"grid grid-cols-2 md:grid-cols-4 gap-4 mb-6\" data-kid=\"89\">\n            <div class=\"p-3 rounded-xl bg-slate-900/40 border border-white/5\" data-kid=\"90\">\n              <span class=\"text-[10px] text-slate-500 uppercase tracking-tight\" data-kid=\"91\">District</span>\n              <p class=\"text-sm font-semibold text-white\" data-kid=\"92\">Gulbarga, KN</p>\n            </div>\n            <div class=\"p-3 rounded-xl bg-slate-900/40 border border-white/5\" data-kid=\"93\">\n              <span class=\"text-[10px] text-slate-500 uppercase tracking-tight\" data-kid=\"94\">Deficit</span>\n              <p class=\"text-sm font-semibold text-cyan-400\" data-kid=\"95\">-24% LTA</p>\n            </div>\n            <div class=\"p-3 rounded-xl bg-slate-900/40 border border-white/5\" data-kid=\"96\">\n              <span class=\"text-[10px] text-slate-500 uppercase tracking-tight\" data-kid=\"97\">Reservoir</span>\n              <p class=\"text-sm font-semibold text-white\" data-kid=\"98\">42% Capacity</p>\n            </div>\n            <div class=\"p-3 rounded-xl bg-slate-900/40 border border-white/5\" data-kid=\"99\">\n              <span class=\"text-[10px] text-slate-500 uppercase tracking-tight\" data-kid=\"100\">Risk Horizon</span>\n              <p class=\"text-sm font-semibold text-white\" data-kid=\"101\">15 Days</p>\n            </div>\n          </div>\n          <div class=\"flex gap-3\" data-kid=\"102\">\n            <button class=\"flex-1 bg-slate-900 hover:bg-slate-800 text-white border border-slate-700 font-bold py-3 rounded-lg transition-all text-sm\" data-kid=\"103\">\n              Initiate Crop Insurance Review\n            </button>\n            <button class=\"px-6 py-3 rounded-lg border border-slate-700 hover:bg-slate-800 transition-all text-sm font-medium text-slate-300\" data-kid=\"104\">\n              More Info\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <aside class=\"space-y-6\" data-kid=\"105\">\n      <div class=\"glass-card p-6 rounded-2xl glow-cyan\" data-kid=\"106\">\n        <h3 class=\"text-lg font-bold text-white mb-6 flex items-center gap-2\" data-kid=\"107\">\n          <i data-lucide=\"bar-chart-2\" class=\"w-5 h-5 text-cyan-400\" data-kid=\"108\"></i>\n          Severity Distribution\n        </h3>\n        <div class=\"space-y-4\" data-kid=\"109\">\n          <div data-kid=\"110\">\n            <div class=\"flex justify-between text-xs font-medium mb-1.5\" data-kid=\"111\">\n              <span class=\"text-rose-400\" data-kid=\"112\">CRITICAL</span>\n              <span class=\"text-white\" data-kid=\"113\">12%</span>\n            </div>\n            <div class=\"h-1.5 w-full bg-slate-900 rounded-full overflow-hidden\" data-kid=\"114\">\n              <div class=\"h-full bg-rose-500 w-[12%]\" data-kid=\"115\"></div>\n            </div>\n          </div>\n          <div data-kid=\"116\">\n            <div class=\"flex justify-between text-xs font-medium mb-1.5\" data-kid=\"117\">\n              <span class=\"text-amber-400\" data-kid=\"118\">HIGH</span>\n              <span class=\"text-white\" data-kid=\"119\">28%</span>\n            </div>\n            <div class=\"h-1.5 w-full bg-slate-900 rounded-full overflow-hidden\" data-kid=\"120\">\n              <div class=\"h-full bg-amber-500 w-[28%]\" data-kid=\"121\"></div>\n            </div>\n          </div>\n          <div data-kid=\"122\">\n            <div class=\"flex justify-between text-xs font-medium mb-1.5\" data-kid=\"123\">\n              <span class=\"text-cyan-400\" data-kid=\"124\">MODERATE</span>\n              <span class=\"text-white\" data-kid=\"125\">60%</span>\n            </div>\n            <div class=\"h-1.5 w-full bg-slate-900 rounded-full overflow-hidden\" data-kid=\"126\">\n              <div class=\"h-full bg-cyan-500 w-[60%]\" data-kid=\"127\"></div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"glass-card p-6 rounded-2xl\" data-kid=\"128\">\n        <h3 class=\"text-lg font-bold text-white mb-4\" data-kid=\"129\">Command History</h3>\n        <div class=\"space-y-4\" data-kid=\"130\">\n          <div class=\"flex gap-3 text-sm border-b border-white/5 pb-4\" data-kid=\"131\">\n            <div class=\"w-8 h-8 rounded-full bg-emerald-500/10 flex items-center justify-center text-emerald-400 shrink-0\" data-kid=\"132\">\n              <i data-lucide=\"check\" class=\"w-4 h-4\" data-kid=\"133\"></i>\n            </div>\n            <div data-kid=\"134\">\n              <p class=\"text-slate-300\" data-kid=\"135\">Evacuation order dispatched for <span class=\"text-white font-medium\" data-kid=\"136\">Lower Majuli</span>.</p>\n              <span class=\"text-[10px] text-slate-500\" data-kid=\"137\">14:22 PM • Admin</span>\n            </div>\n          </div>\n          <div class=\"flex gap-3 text-sm border-b border-white/5 pb-4\" data-kid=\"138\">\n            <div class=\"w-8 h-8 rounded-full bg-cyan-500/10 flex items-center justify-center text-cyan-400 shrink-0\" data-kid=\"139\">\n              <i data-lucide=\"file-text\" class=\"w-4 h-4\" data-kid=\"140\"></i>\n            </div>\n            <div data-kid=\"141\">\n              <p class=\"text-slate-300\" data-kid=\"142\">Drought impact report generated for <span class=\"text-white font-medium\" data-kid=\"143\">Vidarbha</span>.</p>\n              <span class=\"text-[10px] text-slate-500\" data-kid=\"144\">12:05 PM • Analyst</span>\n            </div>\n          </div>\n          <div class=\"flex gap-3 text-sm\" data-kid=\"145\">\n            <div class=\"w-8 h-8 rounded-full bg-amber-500/10 flex items-center justify-center text-amber-400 shrink-0\" data-kid=\"146\">\n              <i data-lucide=\"bell\" class=\"w-4 h-4\" data-kid=\"147\"></i>\n            </div>\n            <div data-kid=\"148\">\n              <p class=\"text-slate-300\" data-kid=\"149\">New heatwave anomaly detected in <span class=\"text-white font-medium\" data-kid=\"150\">Bikaner</span>.</p>\n              <span class=\"text-[10px] text-slate-500\" data-kid=\"151\">11:58 AM • System</span>\n            </div>\n          </div>\n        </div>\n        <button class=\"w-full mt-6 py-2 text-xs font-bold text-slate-500 hover:text-white transition-colors\" data-kid=\"152\">VIEW ALL HISTORY</button>\n      </div>\n\n      <div class=\"glass-card p-6 rounded-2xl bg-cyan-500/5 border-cyan-500/30\" data-kid=\"153\">\n        <h3 class=\"text-sm font-bold text-cyan-100 flex items-center gap-2 mb-3\" data-kid=\"154\">\n          <i data-lucide=\"info\" class=\"w-4 h-4\" data-kid=\"155\"></i>\n          Did you know?\n        </h3>\n        <p class=\"text-xs text-cyan-200/60 leading-relaxed\" data-kid=\"156\">\n          The AI Model <span class=\"text-white\" data-kid=\"157\">XGBoostDrought-v1</span> is currently analyzing soil moisture data from INSAT-3R to predict reservoir drawdown rates.\n        </p>\n      </div>\n    </aside>\n  </div>\n</main>\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"158\"></script>\n<script data-kid=\"159\">\n  lucide.createIcons();\n</script>",
