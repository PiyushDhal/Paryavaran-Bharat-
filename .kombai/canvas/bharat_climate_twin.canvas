      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n\n  :root {\n    --bg-color: #020617;\n    --surface-color: rgba(15, 23, 42, 0.6);\n    --border-color: rgba(34, 211, 238, 0.15);\n    --primary-cyan: #22d3ee;\n    --secondary-emerald: #10b981;\n    --accent-amber: #f59e0b;\n    --error-rose: #f43f5e;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: var(--bg-color);\n    color: #f8fafc;\n    margin: 0;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .radar-grid {\n    background-image: \n      linear-gradient(var(--border-color) 1px, transparent 1px),\n      linear-gradient(90deg, var(--border-color) 1px, transparent 1px);\n    background-size: 40px 40px;\n  }\n\n  .glow-cyan {\n    box-shadow: 0 0 20px rgba(34, 211, 238, 0.08);\n  }\n\n  .glass-card {\n    background: var(--surface-color);\n    backdrop-filter: blur(12px);\n    border: 1px solid var(--border-color);\n    border-radius: 0.75rem;\n  }\n</style>\n\n<div class=\"radar-grid min-h-screen p-6 lg:p-10\" data-kid=\"1\">\n  <div class=\"mx-auto max-w-7xl\" data-kid=\"2\">\n    \n    <div class=\"mb-8 flex flex-col justify-between gap-4 md:flex-row md:items-end\" data-kid=\"3\">\n      <div data-kid=\"4\">\n        <span class=\"inline-flex items-center gap-1.5 rounded-full border border-cyan-400/20 bg-cyan-400/10 px-3 py-1 text-xs font-medium text-cyan-300\" data-kid=\"5\">\n          <span class=\"h-1.5 w-1.5 rounded-full bg-cyan-400 animate-pulse\" data-kid=\"6\"></span>\n          National command dashboard\n        </span>\n        <h1 class=\"mt-4 text-4xl font-bold tracking-tight text-white\" data-kid=\"7\">Climate Operations Overview</h1>\n        <p class=\"mt-2 text-slate-400 max-w-2xl\" data-kid=\"8\">\n          Live satellite feeds, district vulnerability rankings, disaster forecast summaries, and command actions for national resilience.\n        </p>\n      </div>\n      <div class=\"inline-flex items-center gap-2 rounded-lg border border-emerald-500/20 bg-emerald-500/10 px-4 py-2.5 text-sm font-semibold text-emerald-400 backdrop-blur-sm\" data-kid=\"9\">\n        <i class=\"fa-solid fa-satellite-dish\" data-kid=\"10\"></i>\n        742 districts monitored\n      </div>\n    </div>\n\n    \n    <div class=\"mb-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4\" data-kid=\"11\">\n      \n      <div class=\"glass-card glow-cyan p-5\" data-kid=\"12\">\n        <div class=\"flex items-center justify-between text-rose-400\" data-kid=\"13\">\n          <span class=\"text-sm font-medium text-slate-400\" data-kid=\"14\">National Temperature</span>\n          <i class=\"fa-solid fa-fire-flame-curved text-lg\" data-kid=\"15\"></i>\n        </div>\n        <div class=\"mt-3 flex items-baseline gap-2\" data-kid=\"16\">\n          <span class=\"text-3xl font-bold\" data-kid=\"17\">32.4°C</span>\n          <span class=\"text-xs text-rose-400 font-medium\" data-kid=\"18\">+1.2° vs avg</span>\n        </div>\n        <p class=\"mt-1 text-xs text-slate-500\" data-kid=\"19\">Latest monthly average observed</p>\n      </div>\n\n      \n      <div class=\"glass-card glow-cyan p-5\" data-kid=\"20\">\n        <div class=\"flex items-center justify-between text-cyan-400\" data-kid=\"21\">\n          <span class=\"text-sm font-medium text-slate-400\" data-kid=\"22\">Rainfall</span>\n          <i class=\"fa-solid fa-cloud-showers-heavy text-lg\" data-kid=\"23\"></i>\n        </div>\n        <div class=\"mt-3 flex items-baseline gap-2\" data-kid=\"24\">\n          <span class=\"text-3xl font-bold\" data-kid=\"25\">142 mm</span>\n          <span class=\"text-xs text-cyan-400 font-medium\" data-kid=\"26\">85% of normal</span>\n        </div>\n        <p class=\"mt-1 text-xs text-slate-500\" data-kid=\"27\">Observed district mean aggregate</p>\n      </div>\n\n      \n      <div class=\"glass-card glow-cyan p-5\" data-kid=\"28\">\n        <div class=\"flex items-center justify-between text-emerald-400\" data-kid=\"29\">\n          <span class=\"text-sm font-medium text-slate-400\" data-kid=\"30\">Reservoir Status</span>\n          <i class=\"fa-solid fa-droplet text-lg\" data-kid=\"31\"></i>\n        </div>\n        <div class=\"mt-3 flex items-baseline gap-2\" data-kid=\"32\">\n          <span class=\"text-3xl font-bold\" data-kid=\"33\">68%</span>\n          <span class=\"text-xs text-emerald-400 font-medium\" data-kid=\"34\">Stable</span>\n        </div>\n        <p class=\"mt-1 text-xs text-slate-500\" data-kid=\"35\">India-WRIS aggregate storage level</p>\n      </div>\n\n      \n      <div class=\"glass-card glow-cyan p-5\" data-kid=\"36\">\n        <div class=\"flex items-center justify-between text-amber-400\" data-kid=\"37\">\n          <span class=\"text-sm font-medium text-slate-400\" data-kid=\"38\">Air Quality</span>\n          <i class=\"fa-solid fa-tower-broadcast text-lg\" data-kid=\"39\"></i>\n        </div>\n        <div class=\"mt-3 flex items-baseline gap-2\" data-kid=\"40\">\n          <span class=\"text-3xl font-bold\" data-kid=\"41\">118</span>\n          <span class=\"text-xs text-amber-400 font-medium\" data-kid=\"42\">Moderate</span>\n        </div>\n        <p class=\"mt-1 text-xs text-slate-500\" data-kid=\"43\">CPCB national average monitoring</p>\n      </div>\n    </div>\n\n    \n    <div class=\"mb-6 grid gap-6 lg:grid-cols-[1.4fr_0.6fr]\" data-kid=\"44\">\n      \n      <div class=\"glass-card overflow-hidden flex flex-col\" data-kid=\"45\">\n        <div class=\"p-5 border-b border-cyan-500/10 flex items-center justify-between\" data-kid=\"46\">\n          <div data-kid=\"47\">\n            <h2 class=\"font-semibold text-white\" data-kid=\"48\">Digital Twin Snapshot</h2>\n            <p class=\"text-xs text-slate-500 mt-1\" data-kid=\"49\">Satellite overlays with district risk intelligence</p>\n          </div>\n          <div class=\"flex gap-2\" data-kid=\"50\">\n            <button class=\"px-2.5 py-1 text-[10px] uppercase tracking-wider font-bold rounded bg-cyan-500/10 border border-cyan-500/20 text-cyan-400\" data-kid=\"51\">Rainfall</button>\n            <button class=\"px-2.5 py-1 text-[10px] uppercase tracking-wider font-bold rounded hover:bg-white/5 transition-colors border border-white/10 text-slate-400\" data-kid=\"52\">Heat</button>\n            <button class=\"px-2.5 py-1 text-[10px] uppercase tracking-wider font-bold rounded hover:bg-white/5 transition-colors border border-white/10 text-slate-400\" data-kid=\"53\">NDVI</button>\n          </div>\n        </div>\n        <div class=\"relative h-[480px] w-full bg-[#030712] overflow-hidden\" data-kid=\"54\">\n          <img src=\"https://images.unsplash.com/photo-1541185933-ef5d8ed016c2?auto=format&fit=crop&q=80&w=1280\" alt=\"Satellite earth visualization\" class=\"h-full w-full object-cover opacity-60\" decoding=\"async\" loading=\"lazy\" data-kid=\"55\">\n          <div class=\"absolute inset-0 bg-gradient-to-t from-[#020617] via-transparent to-transparent\" data-kid=\"56\"></div>\n          \n          \n          <svg class=\"absolute inset-0 h-full w-full opacity-40 mix-blend-screen\" viewBox=\"0 0 800 500\" data-kid=\"57\">\n             <path d=\"M200,100 Q300,50 400,150 T600,100\" fill=\"none\" stroke=\"#22d3ee\" stroke-width=\"2\" class=\"animate-[pulse_4s_infinite]\" data-kid=\"58\"></path>\n             <path d=\"M150,250 Q350,200 550,300\" fill=\"none\" stroke=\"#10b981\" stroke-width=\"3\" stroke-dasharray=\"10,5\" data-kid=\"59\"></path>\n             <circle cx=\"450\" cy=\"220\" r=\"40\" fill=\"rgba(244, 63, 94, 0.1)\" stroke=\"#f43f5e\" stroke-width=\"1\" data-kid=\"60\"></circle>\n          </svg>\n\n          \n          <div class=\"absolute bottom-6 left-6 flex flex-col gap-2\" data-kid=\"61\">\n            <div class=\"glass-card p-3 flex flex-col gap-3 shadow-2xl\" data-kid=\"62\">\n              <div class=\"flex items-center gap-2\" data-kid=\"63\">\n                <div class=\"h-2 w-10 bg-gradient-to-r from-cyan-500 to-rose-500 rounded\" data-kid=\"64\"></div>\n                <span class=\"text-[10px] font-bold text-slate-400\" data-kid=\"65\">RISK INDEX</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"glass-card flex flex-col\" data-kid=\"66\">\n        <div class=\"p-5 border-b border-cyan-500/10\" data-kid=\"67\">\n          <h2 class=\"font-semibold text-white\" data-kid=\"68\">Real-time Alerts</h2>\n          <p class=\"text-xs text-slate-500 mt-1\" data-kid=\"69\">Critical warnings for emergency operations</p>\n        </div>\n        <div class=\"flex-1 overflow-y-auto p-5 space-y-4\" data-kid=\"70\">\n          \n          <div class=\"p-4 rounded-lg border border-rose-500/20 bg-rose-500/5 hover:border-rose-500/40 transition-all cursor-pointer group\" data-kid=\"71\">\n            <div class=\"flex items-center justify-between mb-3\" data-kid=\"72\">\n              <span class=\"px-2 py-0.5 text-[10px] font-bold uppercase tracking-widest bg-rose-500 text-white rounded\" data-kid=\"73\">CRITICAL</span>\n              <i class=\"fa-solid fa-triangle-exclamation text-rose-400 group-hover:scale-110 transition-transform\" data-kid=\"74\"></i>\n            </div>\n            <h3 class=\"text-sm font-bold text-white mb-1\" data-kid=\"75\">Flash Flood Warning</h3>\n            <p class=\"text-[10px] font-medium text-rose-300 uppercase tracking-wide\" data-kid=\"76\">Dibrugarh, Assam</p>\n            <p class=\"mt-2 text-xs text-slate-400 leading-relaxed\" data-kid=\"77\">Rising Brahmaputra levels expected to breach primary embankments within 6 hours. Evacuation in progress.</p>\n          </div>\n\n          \n          <div class=\"p-4 rounded-lg border border-amber-500/20 bg-amber-500/5 hover:border-amber-500/40 transition-all cursor-pointer group\" data-kid=\"78\">\n            <div class=\"flex items-center justify-between mb-3\" data-kid=\"79\">\n              <span class=\"px-2 py-0.5 text-[10px] font-bold uppercase tracking-widest bg-amber-500 text-white rounded\" data-kid=\"80\">WARNING</span>\n              <i class=\"fa-solid fa-sun text-amber-400 group-hover:scale-110 transition-transform\" data-kid=\"81\"></i>\n            </div>\n            <h3 class=\"text-sm font-bold text-white mb-1\" data-kid=\"82\">Severe Heatwave</h3>\n            <p class=\"text-[10px] font-medium text-amber-300 uppercase tracking-wide\" data-kid=\"83\">Nagpur, Maharashtra</p>\n            <p class=\"mt-2 text-xs text-slate-400 leading-relaxed\" data-kid=\"84\">Temperatures projected to reach 46.5°C. Power grid load alerts active for municipal zones.</p>\n          </div>\n\n          \n          <div class=\"p-4 rounded-lg border border-cyan-500/20 bg-cyan-500/5 hover:border-cyan-500/40 transition-all cursor-pointer group\" data-kid=\"85\">\n            <div class=\"flex items-center justify-between mb-3\" data-kid=\"86\">\n              <span class=\"px-2 py-0.5 text-[10px] font-bold uppercase tracking-widest bg-cyan-500 text-white rounded\" data-kid=\"87\">MONITORING</span>\n              <i class=\"fa-solid fa-water text-cyan-400 group-hover:scale-110 transition-transform\" data-kid=\"88\"></i>\n            </div>\n            <h3 class=\"text-sm font-bold text-white mb-1\" data-kid=\"89\">Water Table Depletion</h3>\n            <p class=\"text-[10px] font-medium text-cyan-300 uppercase tracking-wide\" data-kid=\"90\">Jodhpur, Rajasthan</p>\n            <p class=\"mt-2 text-xs text-slate-400 leading-relaxed\" data-kid=\"91\">Groundwater levels dropped by 1.2m below seasonal baseline. Reservoir drawdown increasing.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"grid gap-6 lg:grid-cols-2\" data-kid=\"92\">\n      \n      <div class=\"glass-card p-6\" data-kid=\"93\">\n        <div class=\"mb-6\" data-kid=\"94\">\n          <h2 class=\"font-semibold text-white\" data-kid=\"95\">Rainfall Trend</h2>\n          <p class=\"text-xs text-slate-500 mt-1\" data-kid=\"96\">National district average, latest 36 observations</p>\n        </div>\n        <div class=\"h-64 w-full\" data-kid=\"97\">\n          <canvas id=\"rainfallChart\" data-kid=\"98\"></canvas>\n        </div>\n      </div>\n\n      \n      <div class=\"glass-card p-6\" data-kid=\"99\">\n        <div class=\"mb-6 flex items-center justify-between\" data-kid=\"100\">\n          <div data-kid=\"101\">\n            <h2 class=\"font-semibold text-white\" data-kid=\"102\">Vulnerability Leaderboard</h2>\n            <p class=\"text-xs text-slate-500 mt-1\" data-kid=\"103\">District-wise composite climate risk ranking</p>\n          </div>\n          <i class=\"fa-solid fa-chart-simple text-slate-600\" data-kid=\"104\"></i>\n        </div>\n        <div class=\"h-64 w-full\" data-kid=\"105\">\n          <canvas id=\"leaderboardChart\" data-kid=\"106\"></canvas>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"107\"></script>\n<script src=\"https://kit.fontawesome.com/your-kit-id.js\" crossorigin=\"anonymous\" data-kid=\"108\"></script>\n\n<script data-kid=\"109\">\n  // Common Chart Options\n  const commonOptions = {\n    responsive: true,\n    maintainAspectRatio: false,\n    plugins: {\n      legend: { display: false }\n    },\n    scales: {\n      y: {\n        grid: { color: 'rgba(255, 255, 255, 0.05)' },\n        ticks: { color: '#64748b', font: { size: 10 } }\n      },\n      x: {\n        grid: { display: false },\n        ticks: { color: '#64748b', font: { size: 10 } }\n      }\n    }\n  };\n\n  // Rainfall Trend Chart\n  const rainfallCtx = document.getElementById('rainfallChart').getContext('2d');\n  const rainfallGradient = rainfallCtx.createLinearGradient(0, 0, 0, 250);\n  rainfallGradient.addColorStop(0, 'rgba(34, 211, 238, 0.2)');\n  rainfallGradient.addColorStop(1, 'rgba(34, 211, 238, 0)');\n\n  new Chart(rainfallCtx, {\n    type: 'line',\n    data: {\n      labels: Array.from({length: 12}, (_, i) => `Month ${i+1}`),\n      datasets: [{\n        label: 'Rainfall',\n        data: [65, 59, 80, 81, 56, 55, 40, 70, 90, 110, 140, 142],\n        borderColor: '#22d3ee',\n        borderWidth: 2,\n        tension: 0.4,\n        fill: true,\n        backgroundColor: rainfallGradient,\n        pointRadius: 0,\n        pointHoverRadius: 5,\n        pointHoverBackgroundColor: '#22d3ee'\n      }]\n    },\n    options: commonOptions\n  });\n\n  // Leaderboard Chart\n  const leaderboardCtx = document.getElementById('leaderboardChart').getContext('2d');\n  new Chart(leaderboardCtx, {\n    type: 'bar',\n    data: {\n      labels: ['Darbhanga', 'Sunderbans', 'Dibrugarh', 'Kutch', 'Nellore', 'Cuttack'],\n      datasets: [{\n        label: 'Risk Score',\n        data: [92, 88, 85, 82, 78, 75],\n        backgroundColor: 'rgba(6, 182, 212, 0.6)',\n        borderColor: '#06b6d4',\n        borderWidth: 1,\n        borderRadius: 4,\n        hoverBackgroundColor: '#06b6d4'\n      }]\n    },\n    options: {\n      ...commonOptions,\n      indexAxis: 'y'\n    }\n  });\n</script>",
