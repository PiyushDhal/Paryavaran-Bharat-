      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');\n\n  body {\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    background-color: #020617;\n  }\n\n  .radar-grid {\n    background-image: \n      linear-gradient(to right, rgba(34, 211, 238, 0.05) 1px, transparent 1px),\n      linear-gradient(to bottom, rgba(34, 211, 238, 0.05) 1px, transparent 1px);\n    background-size: 40px 40px;\n  }\n\n  .glow-border {\n    border: 1px solid rgba(34, 211, 238, 0.2);\n    box-shadow: 0 0 20px rgba(34, 211, 238, 0.05);\n  }\n\n  @keyframes pulse {\n    0% { transform: scale(0.9); opacity: 0.4; }\n    50% { transform: scale(1.1); opacity: 0.7; }\n    100% { transform: scale(0.9); opacity: 0.4; }\n  }\n\n  .map-pulse {\n    animation: pulse 4s infinite ease-in-out;\n  }\n</style>\n\n<div class=\"min-h-screen bg-[#020617] text-slate-100 p-6\" data-kid=\"1\">\n  \n  <div class=\"mb-6\" data-kid=\"2\">\n    <div class=\"inline-flex items-center gap-2 rounded-md border border-cyan-400/20 bg-cyan-400/10 px-3 py-1 text-xs font-medium text-cyan-300\" data-kid=\"3\">\n      <i class=\"fa-solid fa-map-location-dot\" data-kid=\"4\"></i>\n      Full-screen GIS dashboard\n    </div>\n    <h1 class=\"mt-3 text-3xl font-semibold tracking-tight text-white\" data-kid=\"5\">Interactive Digital Twin Map</h1>\n    <p class=\"mt-2 max-w-3xl text-sm text-slate-400\" data-kid=\"6\">\n      Toggle temperature, rainfall, NDVI, air quality, soil moisture, reservoirs, flood, and drought overlays for district-level risk intelligence.\n    </p>\n  </div>\n\n  \n  <div class=\"grid min-h-[calc(100vh-180px)] gap-6 xl:grid-cols-[1fr_360px]\" data-kid=\"7\">\n    \n    \n    <div class=\"relative min-h-[600px] overflow-hidden rounded-xl border border-cyan-300/20 bg-slate-900/40 shadow-[0_0_40px_rgba(34,211,238,0.05)]\" data-kid=\"8\">\n      \n      \n      <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(34,211,238,0.15),transparent_70%)]\" data-kid=\"9\">\n        <div class=\"radar-grid absolute inset-0 opacity-60\" data-kid=\"10\"></div>\n        \n        \n        <div class=\"relative h-full w-full flex items-center justify-center opacity-40\" data-kid=\"11\">\n           <img src=\"https://images.unsplash.com/photo-1524492412937-b28074a5d7da?auto=format&w=1200&q=80&fit=crop\" alt=\"Satellite view\" class=\"absolute inset-0 h-full w-full object-cover mix-blend-overlay grayscale opacity-30\" decoding=\"async\" loading=\"lazy\" data-kid=\"12\">\n        </div>\n\n        \n        \n        <div class=\"absolute top-1/4 left-1/3 group cursor-pointer\" data-kid=\"13\">\n           <div class=\"map-pulse h-10 w-10 rounded-full bg-rose-500/20 border border-rose-500 flex items-center justify-center\" data-kid=\"14\">\n              <div class=\"h-4 w-4 rounded-full bg-rose-500 shadow-[0_0_10px_#f43f5e]\" data-kid=\"15\"></div>\n           </div>\n           <div class=\"absolute -top-8 left-1/2 -translate-x-1/2 bg-slate-950/90 border border-cyan-300/30 px-2 py-1 rounded text-[10px] whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"16\">\n              Lakhimpur (Flood Critical)\n           </div>\n        </div>\n\n        <div class=\"absolute top-1/2 left-1/2 group cursor-pointer\" data-kid=\"17\">\n           <div class=\"map-pulse h-8 w-8 rounded-full bg-amber-500/20 border border-amber-500 flex items-center justify-center\" style=\"animation-delay: 1s;\" data-kid=\"18\">\n              <div class=\"h-3 w-3 rounded-full bg-amber-500 shadow-[0_0_10px_#f59e0b]\" data-kid=\"19\"></div>\n           </div>\n        </div>\n\n        <div class=\"absolute bottom-1/3 right-1/4 group cursor-pointer\" data-kid=\"20\">\n           <div class=\"map-pulse h-12 w-12 rounded-full bg-cyan-500/20 border border-cyan-500 flex items-center justify-center\" style=\"animation-delay: 2s;\" data-kid=\"21\">\n              <div class=\"h-5 w-5 rounded-full bg-cyan-500 shadow-[0_0_10px_#06b6d4]\" data-kid=\"22\"></div>\n           </div>\n        </div>\n\n        \n        <div class=\"absolute left-6 top-6 max-w-sm\" data-kid=\"23\">\n           <div class=\"inline-flex items-center gap-2 rounded-full border border-emerald-400/20 bg-emerald-400/10 px-2 py-0.5 text-[10px] font-medium text-emerald-300\" data-kid=\"24\">\n             LIVE DATA STREAM ACTIVE\n           </div>\n           <h2 class=\"mt-3 text-2xl font-semibold text-white\" data-kid=\"25\">India Climate Risk Mesh</h2>\n           <p class=\"mt-2 text-sm text-slate-300 leading-relaxed\" data-kid=\"26\">\n             Aggregated risk assessment across 700+ districts using multi-modal satellite fusion.\n           </p>\n        </div>\n      </div>\n\n      \n      <div class=\"absolute bottom-6 left-6 right-6 flex flex-wrap items-center gap-2 rounded-lg border border-cyan-300/20 bg-slate-950/85 p-3 backdrop-blur-md shadow-2xl\" data-kid=\"27\">\n        <div class=\"flex items-center gap-2 pr-4 border-r border-cyan-300/10 text-cyan-200\" data-kid=\"28\">\n          <i class=\"fa-solid fa-layer-group text-sm\" data-kid=\"29\"></i>\n          <span class=\"text-[10px] font-bold uppercase tracking-wider\" data-kid=\"30\">Layers</span>\n        </div>\n        <div class=\"flex flex-wrap gap-2\" data-kid=\"31\">\n          <button class=\"rounded-md bg-white/5 px-3 py-1.5 text-xs font-medium text-slate-300 hover:bg-white/10 transition\" data-kid=\"32\">Temperature</button>\n          <button class=\"rounded-md bg-white/5 px-3 py-1.5 text-xs font-medium text-slate-300 hover:bg-white/10 transition\" data-kid=\"33\">NDVI</button>\n          <button class=\"rounded-md bg-white/5 px-3 py-1.5 text-xs font-medium text-slate-300 hover:bg-white/10 transition\" data-kid=\"34\">Soil Moisture</button>\n          <button class=\"rounded-md bg-cyan-500 px-3 py-1.5 text-xs font-semibold text-slate-950 shadow-[0_0_15px_rgba(6,182,212,0.4)]\" data-kid=\"35\">Flood Risk</button>\n          <button class=\"rounded-md bg-white/5 px-3 py-1.5 text-xs font-medium text-slate-300 hover:bg-white/10 transition\" data-kid=\"36\">Drought Risk</button>\n          <button class=\"rounded-md bg-white/5 px-3 py-1.5 text-xs font-medium text-slate-300 hover:bg-white/10 transition\" data-kid=\"37\">Air Quality</button>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"flex flex-col gap-6\" data-kid=\"38\">\n      \n      <div class=\"rounded-xl border border-cyan-300/20 bg-slate-900/60 p-6 backdrop-blur-sm shadow-xl\" data-kid=\"39\">\n        <div class=\"flex items-center justify-between gap-4\" data-kid=\"40\">\n          <div data-kid=\"41\">\n            <p class=\"text-xs font-medium uppercase tracking-widest text-slate-500\" data-kid=\"42\">Selected Region</p>\n            <h3 class=\"mt-1 text-2xl font-bold text-white tracking-tight\" data-kid=\"43\">Dibrugarh</h3>\n            <p class=\"text-sm font-medium text-cyan-400\" data-kid=\"44\">Assam, NE India</p>\n          </div>\n          <button class=\"grid h-10 w-10 place-items-center rounded-lg border border-cyan-300/30 bg-cyan-400/5 text-cyan-100 hover:bg-cyan-400/20 transition shadow-lg\" data-kid=\"45\">\n            <i class=\"fa-solid fa-location-crosshairs text-lg\" data-kid=\"46\"></i>\n          </button>\n        </div>\n\n        <div class=\"mt-8 space-y-5\" data-kid=\"47\">\n          \n          <div data-kid=\"48\">\n            <div class=\"mb-2 flex justify-between items-end\" data-kid=\"49\">\n              <span class=\"text-sm font-medium text-slate-300\" data-kid=\"50\">Flood Exposure</span>\n              <span class=\"text-sm font-bold text-rose-400\" data-kid=\"51\">88.4</span>\n            </div>\n            <div class=\"h-2 w-full overflow-hidden rounded-full bg-white/10\" data-kid=\"52\">\n              <div class=\"h-full rounded-full bg-rose-500 shadow-[0_0_10px_rgba(244,63,94,0.5)]\" style=\"width: 88.4%\" data-kid=\"53\"></div>\n            </div>\n          </div>\n\n          \n          <div data-kid=\"54\">\n            <div class=\"mb-2 flex justify-between items-end\" data-kid=\"55\">\n              <span class=\"text-sm font-medium text-slate-300\" data-kid=\"56\">Drought Index</span>\n              <span class=\"text-sm font-bold text-emerald-400\" data-kid=\"57\">12.0</span>\n            </div>\n            <div class=\"h-2 w-full overflow-hidden rounded-full bg-white/10\" data-kid=\"58\">\n              <div class=\"h-full rounded-full bg-emerald-500\" style=\"width: 12%\" data-kid=\"59\"></div>\n            </div>\n          </div>\n\n          \n          <div data-kid=\"60\">\n            <div class=\"mb-2 flex justify-between items-end\" data-kid=\"61\">\n              <span class=\"text-sm font-medium text-slate-300\" data-kid=\"62\">Heatwave Risk</span>\n              <span class=\"text-sm font-bold text-amber-400\" data-kid=\"63\">45.2</span>\n            </div>\n            <div class=\"h-2 w-full overflow-hidden rounded-full bg-white/10\" data-kid=\"64\">\n              <div class=\"h-full rounded-full bg-amber-500\" style=\"width: 45.2%\" data-kid=\"65\"></div>\n            </div>\n          </div>\n\n          \n          <div data-kid=\"66\">\n            <div class=\"mb-2 flex justify-between items-end\" data-kid=\"67\">\n              <span class=\"text-sm font-medium text-slate-300\" data-kid=\"68\">Water Stress</span>\n              <span class=\"text-sm font-bold text-cyan-400\" data-kid=\"69\">22.8</span>\n            </div>\n            <div class=\"h-2 w-full overflow-hidden rounded-full bg-white/10\" data-kid=\"70\">\n              <div class=\"h-full rounded-full bg-cyan-500\" style=\"width: 22.8%\" data-kid=\"71\"></div>\n            </div>\n          </div>\n\n          \n          <div class=\"pt-4 mt-6 border-t border-white/5\" data-kid=\"72\">\n            <div class=\"mb-2 flex justify-between items-end\" data-kid=\"73\">\n              <span class=\"text-sm font-bold text-white uppercase tracking-wider\" data-kid=\"74\">Composite Climate Risk</span>\n              <span class=\"text-lg font-black text-rose-500\" data-kid=\"75\">72.4</span>\n            </div>\n            <div class=\"h-3 w-full overflow-hidden rounded-full bg-white/10\" data-kid=\"76\">\n              <div class=\"h-full rounded-full bg-gradient-to-r from-emerald-500 via-amber-500 to-rose-500\" style=\"width: 72.4%\" data-kid=\"77\"></div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"mt-8 rounded-lg border border-cyan-300/10 bg-cyan-400/5 p-4\" data-kid=\"78\">\n          <p class=\"text-[11px] leading-relaxed text-slate-400\" data-kid=\"79\">\n            <span class=\"text-cyan-300 font-bold uppercase mr-1\" data-kid=\"80\">Note:</span>\n            Animated climate overlays can be replaced with live raster tiles from Bhuvan, NRSC, IMD, India-WRIS, and CPCB without changing the map contract.\n          </p>\n        </div>\n      </div>\n\n      \n      <div class=\"flex-1 rounded-xl border border-white/5 bg-slate-900/40 p-5\" data-kid=\"81\">\n         <div class=\"flex items-center gap-2 mb-4 text-xs font-bold text-slate-500 uppercase tracking-widest\" data-kid=\"82\">\n            <i class=\"fa-solid fa-cloud-bolt text-cyan-400\" data-kid=\"83\"></i>\n            7-Day Forecast\n         </div>\n         <div class=\"space-y-3\" data-kid=\"84\">\n            <div class=\"flex items-center justify-between text-sm py-2 border-b border-white/5\" data-kid=\"85\">\n               <span class=\"text-slate-300\" data-kid=\"86\">Monsoon Surge</span>\n               <span class=\"font-bold text-emerald-400\" data-kid=\"87\">High Prob</span>\n            </div>\n            <div class=\"flex items-center justify-between text-sm py-2 border-b border-white/5\" data-kid=\"88\">\n               <span class=\"text-slate-300\" data-kid=\"89\">River Level Δ</span>\n               <span class=\"font-bold text-rose-400\" data-kid=\"90\">+1.2m</span>\n            </div>\n            <div class=\"flex items-center justify-between text-sm py-2 border-b border-white/5\" data-kid=\"91\">\n               <span class=\"text-slate-300\" data-kid=\"92\">Cloud Cover</span>\n               <span class=\"font-bold text-white\" data-kid=\"93\">82%</span>\n            </div>\n         </div>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\" data-kid=\"94\">",
