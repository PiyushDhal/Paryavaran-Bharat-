      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n\n  :root {\n    --background: 220 42% 7%;\n    --foreground: 192 35% 96%;\n    --card: 218 36% 10%;\n    --primary: 185 92% 46%;\n    --secondary: 154 68% 42%;\n    --border: 196 42% 22%;\n  }\n\n  body {\n    margin: 0;\n    min-height: 100vh;\n    font-family: 'Inter', sans-serif;\n    color: hsl(var(--foreground));\n    background:\n      radial-gradient(circle at 18% 12%, rgba(34, 211, 238, 0.13), transparent 30%),\n      radial-gradient(circle at 82% 16%, rgba(34, 197, 94, 0.11), transparent 28%),\n      linear-gradient(135deg, #04111f 0%, #071829 48%, #06120d 100%);\n    overflow: hidden;\n  }\n\n  .glass-panel {\n    border: 1px solid rgba(125, 211, 252, 0.22);\n    background: rgba(8, 20, 34, 0.74);\n    box-shadow: 0 22px 80px rgba(0, 0, 0, 0.26);\n    backdrop-filter: blur(20px);\n  }\n\n  .radar-grid {\n    background-image: \n      linear-gradient(rgba(34, 211, 238, 0.08) 1px, transparent 1px), \n      linear-gradient(90deg, rgba(34, 211, 238, 0.08) 1px, transparent 1px);\n    background-size: 40px 40px;\n  }\n\n  .glow-cyan {\n    box-shadow: 0 0 20px rgba(34, 211, 238, 0.3);\n  }\n\n  /* Custom Timeline Range Styling */\n  .timeline-slider {\n    -webkit-appearance: none;\n    width: 100%;\n    height: 4px;\n    background: rgba(255, 255, 255, 0.1);\n    border-radius: 2px;\n    outline: none;\n  }\n\n  .timeline-slider::-webkit-slider-thumb {\n    -webkit-appearance: none;\n    appearance: none;\n    width: 16px;\n    height: 16px;\n    background: #06b6d4;\n    border: 2px solid #fff;\n    border-radius: 50%;\n    cursor: pointer;\n    box-shadow: 0 0 10px rgba(6, 182, 212, 0.8);\n    transition: all 0.2s ease;\n  }\n\n  .timeline-slider::-webkit-slider-thumb:hover {\n    transform: scale(1.2);\n    box-shadow: 0 0 15px rgba(6, 182, 212, 1);\n  }\n\n  .active-year {\n    color: #06b6d4;\n    text-shadow: 0 0 8px rgba(6, 182, 212, 0.5);\n    font-weight: 700;\n  }\n</style>\n\n<div class=\"h-screen w-full relative flex flex-col radar-grid\" data-kid=\"1\">\n  \n  <header class=\"flex items-center justify-between px-8 py-4 glass-panel border-b border-white/10 z-50\" data-kid=\"2\">\n    <div class=\"flex items-center gap-4\" data-kid=\"3\">\n      <div class=\"w-10 h-10 bg-primary flex items-center justify-center rounded-lg glow-cyan\" data-kid=\"4\">\n        <i data-lucide=\"globe\" class=\"text-slate-950 w-6 h-6\" data-kid=\"5\"></i>\n      </div>\n      <div data-kid=\"6\">\n        <h1 class=\"text-xl font-bold tracking-tight text-white\" data-kid=\"7\">Bharat Climate Twin</h1>\n        <span class=\"text-xs text-primary uppercase tracking-widest font-semibold\" data-kid=\"8\">National Command Center</span>\n      </div>\n    </div>\n    <div class=\"flex items-center gap-6\" data-kid=\"9\">\n      <nav class=\"hidden md:flex items-center gap-8 text-sm font-medium text-slate-400\" data-kid=\"10\">\n        <a href=\"#\" class=\"hover:text-primary transition-colors\" data-kid=\"11\">Dashboard</a>\n        <a href=\"#\" class=\"text-white border-b-2 border-primary pb-1\" data-kid=\"12\">Digital Twin Map</a>\n        <a href=\"#\" class=\"hover:text-primary transition-colors\" data-kid=\"13\">Simulator</a>\n        <a href=\"#\" class=\"hover:text-primary transition-colors\" data-kid=\"14\">Risk Center</a>\n      </nav>\n      <div class=\"flex items-center gap-3\" data-kid=\"15\">\n        <button class=\"p-2 rounded-full hover:bg-white/5 transition-colors text-slate-400\" data-kid=\"16\">\n          <i data-lucide=\"bell\" class=\"w-5 h-5\" data-kid=\"17\"></i>\n        </button>\n        <div class=\"w-8 h-8 rounded-full bg-slate-800 border border-white/10 flex items-center justify-center cursor-pointer\" data-kid=\"18\">\n          <i data-lucide=\"user\" class=\"w-4 h-4 text-slate-300\" data-kid=\"19\"></i>\n        </div>\n      </div>\n    </div>\n  </header>\n\n  <main class=\"flex-1 relative flex overflow-hidden\" data-kid=\"20\">\n    \n    <aside class=\"w-80 glass-panel h-full border-r border-white/10 p-6 z-40 flex flex-col gap-8 overflow-y-auto\" data-kid=\"21\">\n      <div data-kid=\"22\">\n        <h2 class=\"text-xs font-bold text-slate-500 uppercase tracking-widest mb-4\" data-kid=\"23\">Risk Parameters</h2>\n        <div class=\"space-y-3\" data-kid=\"24\">\n          <button class=\"w-full flex items-center justify-between p-3 rounded-lg bg-primary/10 border border-primary/20 text-primary group\" data-kid=\"25\">\n            <div class=\"flex items-center gap-3\" data-kid=\"26\">\n              <i data-lucide=\"cloud-rain\" class=\"w-4 h-4\" data-kid=\"27\"></i>\n              <span class=\"text-sm font-semibold\" data-kid=\"28\">Rainfall Analysis</span>\n            </div>\n            <i data-lucide=\"check\" class=\"w-4 h-4\" data-kid=\"29\"></i>\n          </button>\n          <button class=\"w-full flex items-center justify-between p-3 rounded-lg bg-white/5 border border-white/10 text-slate-300 hover:bg-white/10 transition-all\" data-kid=\"30\">\n            <div class=\"flex items-center gap-3\" data-kid=\"31\">\n              <i data-lucide=\"thermometer\" class=\"w-4 h-4\" data-kid=\"32\"></i>\n              <span class=\"text-sm font-medium\" data-kid=\"33\">Temperature Anomaly</span>\n            </div>\n          </button>\n          <button class=\"w-full flex items-center justify-between p-3 rounded-lg bg-white/5 border border-white/10 text-slate-300 hover:bg-white/10 transition-all\" data-kid=\"34\">\n            <div class=\"flex items-center gap-3\" data-kid=\"35\">\n              <i data-lucide=\"droplets\" class=\"w-4 h-4\" data-kid=\"36\"></i>\n              <span class=\"text-sm font-medium\" data-kid=\"37\">Soil Moisture Index</span>\n            </div>\n          </button>\n        </div>\n      </div>\n\n      <div data-kid=\"38\">\n        <h2 class=\"text-xs font-bold text-slate-500 uppercase tracking-widest mb-4\" data-kid=\"39\">Active Analytics</h2>\n        <div class=\"space-y-4\" data-kid=\"40\">\n          <div class=\"p-4 rounded-xl bg-slate-900/50 border border-white/5\" data-kid=\"41\">\n            <div class=\"flex justify-between items-center mb-2\" data-kid=\"42\">\n              <span class=\"text-xs text-slate-400\" data-kid=\"43\">Avg. Risk Level</span>\n              <span class=\"text-xs font-bold text-primary\" data-kid=\"44\">64%</span>\n            </div>\n            <div class=\"w-full h-1.5 bg-white/10 rounded-full overflow-hidden\" data-kid=\"45\">\n              <div class=\"h-full bg-primary glow-cyan\" style=\"width: 64%\" data-kid=\"46\"></div>\n            </div>\n            <p class=\"mt-2 text-[10px] text-slate-500 leading-tight\" data-kid=\"47\">Projected data based on current 2030 simulation trends.</p>\n          </div>\n        </div>\n      </div>\n    </aside>\n\n    \n    <div class=\"flex-1 relative\" data-kid=\"48\">\n      \n      <div class=\"absolute inset-0 bg-[#081422] z-0 overflow-hidden\" data-kid=\"49\">\n        <img src=\"https://images.unsplash.com/photo-1544077960-604201fe74bc?auto=format&fit=crop&q=80&w=1280\" alt=\"Satellite Map Background\" class=\"w-full h-full object-cover opacity-30 mix-blend-luminosity scale-110\" decoding=\"async\" loading=\"lazy\" data-kid=\"50\">\n        \n        \n        <div class=\"absolute top-1/3 left-1/2 w-48 h-48 bg-primary/10 border-2 border-primary/30 rounded-full flex items-center justify-center animate-pulse\" data-kid=\"51\">\n          <div class=\"w-4 h-4 bg-primary rounded-full glow-cyan\" data-kid=\"52\"></div>\n          <div class=\"absolute -top-12 bg-slate-900/80 border border-primary/40 p-2 rounded-md backdrop-blur-sm shadow-xl\" data-kid=\"53\">\n             <span class=\"text-[10px] text-primary font-bold\" data-kid=\"54\">KUTCH: HIGH RISK (78)</span>\n          </div>\n        </div>\n\n        \n        <div class=\"absolute top-6 right-6 flex flex-col gap-4 z-10\" data-kid=\"55\">\n          <div class=\"glass-panel p-4 rounded-xl w-64\" data-kid=\"56\">\n            <div class=\"flex items-center gap-3 mb-3\" data-kid=\"57\">\n               <div class=\"p-2 rounded-lg bg-red-500/10 text-red-400 border border-red-500/20\" data-kid=\"58\">\n                  <i data-lucide=\"flame\" class=\"w-4 h-4\" data-kid=\"59\"></i>\n               </div>\n               <span class=\"text-sm font-semibold text-white\" data-kid=\"60\">Heatwave Alert</span>\n            </div>\n            <p class=\"text-xs text-slate-400 mb-2\" data-kid=\"61\">North-Western districts showing 20% increase in intensity by 2030.</p>\n            <span class=\"text-[10px] px-2 py-0.5 rounded bg-red-500 text-white font-bold\" data-kid=\"62\">CRITICAL</span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"absolute bottom-10 left-1/2 -translate-x-1/2 w-[600px] z-50\" data-kid=\"63\">\n        <div class=\"glass-panel p-6 rounded-2xl shadow-2xl border border-white/20\" data-kid=\"64\">\n          <div class=\"flex justify-between items-center mb-6\" data-kid=\"65\">\n            <h3 class=\"text-xs font-bold text-slate-400 uppercase tracking-widest flex items-center gap-2\" data-kid=\"66\">\n              <i data-lucide=\"calendar\" class=\"w-3 h-3 text-primary\" data-kid=\"67\"></i>\n              Climate Timeline Projection\n            </h3>\n            <div class=\"flex items-center gap-2 px-3 py-1 bg-primary/10 border border-primary/20 rounded-full\" data-kid=\"68\">\n              <span class=\"w-2 h-2 bg-primary rounded-full animate-ping\" data-kid=\"69\"></span>\n              <span class=\"text-[10px] font-bold text-primary tracking-tighter\" data-kid=\"70\">SIMULATING IMPACTS</span>\n            </div>\n          </div>\n\n          <div class=\"relative px-2\" data-kid=\"71\">\n            \n            <div class=\"flex justify-between mb-4 text-[11px] font-medium text-slate-500\" data-kid=\"72\">\n              <span class=\"active-year\" data-kid=\"73\">2020</span>\n              <span class=\"hover:text-white transition-colors cursor-pointer\" data-kid=\"74\">2025</span>\n              <span class=\"hover:text-white transition-colors cursor-pointer\" data-kid=\"75\">2030</span>\n              <span class=\"hover:text-white transition-colors cursor-pointer\" data-kid=\"76\">2040</span>\n              <span class=\"hover:text-white transition-colors cursor-pointer\" data-kid=\"77\">2050</span>\n            </div>\n\n            \n            <input type=\"range\" min=\"0\" max=\"100\" value=\"0\" class=\"timeline-slider\" data-kid=\"78\">\n\n            \n            <div class=\"absolute -top-10 left-0 text-[9px] font-bold text-primary/60 flex items-center gap-1 opacity-0 hover:opacity-100 transition-opacity\" data-kid=\"79\">\n              <i data-lucide=\"refresh-cw\" class=\"w-3 h-3 animate-spin\" data-kid=\"80\"></i>\n              UPDATING GEOSPATIAL OVERLAYS...\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </main>\n</div>\n\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"81\"></script>\n<script data-kid=\"82\">\n  lucide.createIcons();\n  \n  // Minimal interaction for timeline\n  const slider = document.querySelector('.timeline-slider');\n  const years = document.querySelectorAll('.relative.px-2 span');\n  \n  slider.addEventListener('input', (e) => {\n    const val = e.target.value;\n    const yearIdx = Math.round(val / 25);\n    \n    years.forEach((y, idx) => {\n      if(idx === yearIdx) {\n        y.classList.add('active-year');\n        y.classList.remove('text-slate-500');\n      } else {\n        y.classList.remove('active-year');\n        y.classList.add('text-slate-500');\n      }\n    });\n  });\n</script>",
