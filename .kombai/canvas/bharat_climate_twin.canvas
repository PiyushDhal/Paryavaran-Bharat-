    "var_32bcfdd043a9": {
      "type": "variant",
      "label": "Analytics Dashboard",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 4620,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "generation": {
        "prompt": "",
        "config": {}
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n\n  :root {\n    --bg-main: #020617;\n    --card-bg: rgba(15, 23, 42, 0.4);\n    --cyan-accent: #06b6d4;\n    --emerald-accent: #10b981;\n    --rose-accent: #f87171;\n    --amber-accent: #fbbf24;\n    --border-color: rgba(34, 211, 238, 0.15);\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: var(--bg-main);\n    color: #f8fafc;\n    margin: 0;\n    min-height: 100vh;\n  }\n\n  .radar-grid {\n    background-image: radial-gradient(circle at 1px 1px, rgba(34, 211, 238, 0.05) 1px, transparent 0);\n    background-size: 24px 24px;\n  }\n\n  .glass-card {\n    background: var(--card-bg);\n    backdrop-filter: blur(12px);\n    border: 1px solid var(--border-color);\n    transition: all 0.3s ease;\n  }\n\n  .glass-card:hover {\n    border-color: rgba(34, 211, 238, 0.3);\n    box-shadow: 0 0 20px rgba(34, 211, 238, 0.05);\n  }\n\n  .glow-cyan { text-shadow: 0 0 10px rgba(6, 182, 212, 0.5); }\n  .glow-emerald { text-shadow: 0 0 10px rgba(16, 185, 129, 0.5); }\n  .glow-rose { text-shadow: 0 0 10px rgba(248, 113, 113, 0.5); }\n  .glow-amber { text-shadow: 0 0 10px rgba(251, 191, 36, 0.5); }\n\n  .scanline {\n    position: relative;\n  }\n  .scanline::after {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(to bottom, transparent 50%, rgba(34, 211, 238, 0.02) 50%);\n    background-size: 100% 4px;\n    pointer-events: none;\n  }\n\n  .chart-container {\n    height: 240px;\n    width: 100%;\n  }\n</style>\n\n<main class=\"min-h-screen radar-grid p-6 lg:p-12\" data-kid=\"1\">\n  <div class=\"max-w-7xl mx-auto space-y-8\" data-kid=\"2\">\n    \n    <header class=\"space-y-4\" data-kid=\"3\">\n      <div class=\"inline-flex items-center gap-2 rounded-md border border-cyan-400/30 bg-cyan-400/10 px-3 py-1 text-sm font-medium text-cyan-200 backdrop-blur-sm\" data-kid=\"4\">\n        <i data-lucide=\"bar-chart-3\" class=\"w-4 h-4\" data-kid=\"5\"></i>\n        Climate Analytics Dashboard\n      </div>\n      <h1 class=\"text-4xl font-bold tracking-tight text-white\" data-kid=\"6\">National Climate Analytics</h1>\n      <p class=\"text-slate-400 max-w-2xl leading-relaxed\" data-kid=\"7\">\n        Trends for temperature, rainfall, reservoir storage, air quality, and disaster forecast readiness with district-level aggregate telemetry.\n      </p>\n    </header>\n\n    \n    <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4\" data-kid=\"8\">\n      \n      <div class=\"glass-card p-6 rounded-xl relative overflow-hidden group\" data-kid=\"9\">\n        <div class=\"absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity\" data-kid=\"10\">\n          <i data-lucide=\"flame\" class=\"w-12 h-12 text-rose-400\" data-kid=\"11\"></i>\n        </div>\n        <p class=\"text-xs font-medium text-slate-500 uppercase tracking-wider\" data-kid=\"12\">Temperature</p>\n        <h2 class=\"mt-2 text-3xl font-bold text-rose-400 glow-rose\" data-kid=\"13\">28.4 C</h2>\n        <p class=\"mt-1 text-xs text-slate-400\" data-kid=\"14\">Latest national average</p>\n      </div>\n\n      \n      <div class=\"glass-card p-6 rounded-xl relative overflow-hidden group\" data-kid=\"15\">\n        <div class=\"absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity\" data-kid=\"16\">\n          <i data-lucide=\"cloud-rain\" class=\"w-12 h-12 text-cyan-400\" data-kid=\"17\"></i>\n        </div>\n        <p class=\"text-xs font-medium text-slate-500 uppercase tracking-wider\" data-kid=\"18\">Rainfall</p>\n        <h2 class=\"mt-2 text-3xl font-bold text-cyan-400 glow-cyan\" data-kid=\"19\">142 mm</h2>\n        <p class=\"mt-1 text-xs text-slate-400\" data-kid=\"20\">Latest national average</p>\n      </div>\n\n      \n      <div class=\"glass-card p-6 rounded-xl relative overflow-hidden group\" data-kid=\"21\">\n        <div class=\"absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity\" data-kid=\"22\">\n          <i data-lucide=\"droplets\" class=\"w-12 h-12 text-emerald-400\" data-kid=\"23\"></i>\n        </div>\n        <p class=\"text-xs font-medium text-slate-500 uppercase tracking-wider\" data-kid=\"24\">Reservoir</p>\n        <h2 class=\"mt-2 text-3xl font-bold text-emerald-400 glow-emerald\" data-kid=\"25\">64%</h2>\n        <p class=\"mt-1 text-xs text-slate-400\" data-kid=\"26\">Current storage status</p>\n      </div>\n\n      \n      <div class=\"glass-card p-6 rounded-xl relative overflow-hidden group\" data-kid=\"27\">\n        <div class=\"absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity\" data-kid=\"28\">\n          <i data-lucide=\"radio-tower\" class=\"w-12 h-12 text-amber-400\" data-kid=\"29\"></i>\n        </div>\n        <p class=\"text-xs font-medium text-slate-500 uppercase tracking-wider\" data-kid=\"30\">AQI</p>\n        <h2 class=\"mt-2 text-3xl font-bold text-amber-400 glow-amber\" data-kid=\"31\">156</h2>\n        <p class=\"mt-1 text-xs text-slate-400\" data-kid=\"32\">Air quality index</p>\n      </div>\n    </div>\n\n    \n    <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-6\" data-kid=\"33\">\n      \n      <div class=\"glass-card p-6 rounded-2xl\" data-kid=\"34\">\n        <div class=\"mb-6 flex items-center justify-between\" data-kid=\"35\">\n          <div data-kid=\"36\">\n            <h3 class=\"text-lg font-semibold text-white\" data-kid=\"37\">National Temperature Trends</h3>\n            <p class=\"text-xs text-slate-500\" data-kid=\"38\">Monthly district average, latest 36 points.</p>\n          </div>\n          <i data-lucide=\"flame\" class=\"w-5 h-5 text-rose-400\" data-kid=\"39\"></i>\n        </div>\n        <div class=\"chart-container\" data-kid=\"40\">\n          <canvas id=\"tempChart\" data-kid=\"41\"></canvas>\n        </div>\n      </div>\n\n      \n      <div class=\"glass-card p-6 rounded-2xl\" data-kid=\"42\">\n        <div class=\"mb-6 flex items-center justify-between\" data-kid=\"43\">\n          <div data-kid=\"44\">\n            <h3 class=\"text-lg font-semibold text-white\" data-kid=\"45\">Rainfall Trends</h3>\n            <p class=\"text-xs text-slate-500\" data-kid=\"46\">IMD-style precipitation aggregate (mm).</p>\n          </div>\n          <i data-lucide=\"cloud-rain\" class=\"w-5 h-5 text-cyan-400\" data-kid=\"47\"></i>\n        </div>\n        <div class=\"chart-container\" data-kid=\"48\">\n          <canvas id=\"rainChart\" data-kid=\"49\"></canvas>\n        </div>\n      </div>\n\n      \n      <div class=\"glass-card p-6 rounded-2xl\" data-kid=\"50\">\n        <div class=\"mb-6 flex items-center justify-between\" data-kid=\"51\">\n          <div data-kid=\"52\">\n            <h3 class=\"text-lg font-semibold text-white\" data-kid=\"53\">Reservoir Status</h3>\n            <p class=\"text-xs text-slate-500\" data-kid=\"54\">India-WRIS compatible storage feed (%)</p>\n          </div>\n          <i data-lucide=\"droplets\" class=\"w-5 h-5 text-emerald-400\" data-kid=\"55\"></i>\n        </div>\n        <div class=\"chart-container\" data-kid=\"56\">\n          <canvas id=\"reservoirChart\" data-kid=\"57\"></canvas>\n        </div>\n      </div>\n\n      \n      <div class=\"glass-card p-6 rounded-2xl\" data-kid=\"58\">\n        <div class=\"mb-6 flex items-center justify-between\" data-kid=\"59\">\n          <div data-kid=\"60\">\n            <h3 class=\"text-lg font-semibold text-white\" data-kid=\"61\">Air Quality Index</h3>\n            <p class=\"text-xs text-slate-500\" data-kid=\"62\">CPCB-style district AQI aggregate.</p>\n          </div>\n          <i data-lucide=\"radio-tower\" class=\"w-5 h-5 text-amber-400\" data-kid=\"63\"></i>\n        </div>\n        <div class=\"chart-container\" data-kid=\"64\">\n          <canvas id=\"aqiChart\" data-kid=\"65\"></canvas>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"glass-card p-8 rounded-2xl scanline\" data-kid=\"66\">\n      <div class=\"mb-8 border-b border-cyan-400/10 pb-4\" data-kid=\"67\">\n        <h3 class=\"text-xl font-bold text-white\" data-kid=\"68\">Disaster Forecast Summary</h3>\n        <p class=\"text-sm text-slate-400 mt-1\" data-kid=\"69\">Model facades prepared for AI integration and scikit-learn pipelines.</p>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\" data-kid=\"70\">\n        \n        <div class=\"p-6 rounded-xl bg-slate-900/40 border border-white/5 hover:border-cyan-400/20 transition-all\" data-kid=\"71\">\n          <div class=\"flex items-center gap-3 mb-4\" data-kid=\"72\">\n            <div class=\"w-10 h-10 rounded-lg bg-cyan-400/10 flex items-center justify-center text-cyan-400 border border-cyan-400/20\" data-kid=\"73\">\n              <i data-lucide=\"waves\" class=\"w-5 h-5\" data-kid=\"74\"></i>\n            </div>\n            <h4 class=\"font-semibold text-white\" data-kid=\"75\">Flood Forecast</h4>\n          </div>\n          <p class=\"text-sm text-slate-400 leading-relaxed mb-6\" data-kid=\"76\">\n            Analyzing rainfall patterns, river levels, and soil saturation for early inundation warnings.\n          </p>\n          <span class=\"inline-flex items-center rounded-full bg-cyan-400/10 px-3 py-1 text-xs font-semibold text-cyan-300 border border-cyan-400/20\" data-kid=\"77\">\n            RandomForestFlood-v1\n          </span>\n        </div>\n\n        \n        <div class=\"p-6 rounded-xl bg-slate-900/40 border border-white/5 hover:border-emerald-400/20 transition-all\" data-kid=\"78\">\n          <div class=\"flex items-center gap-3 mb-4\" data-kid=\"79\">\n            <div class=\"w-10 h-10 rounded-lg bg-emerald-400/10 flex items-center justify-center text-emerald-400 border border-emerald-400/20\" data-kid=\"80\">\n              <i data-lucide=\"sprout\" class=\"w-5 h-5\" data-kid=\"81\"></i>\n            </div>\n            <h4 class=\"font-semibold text-white\" data-kid=\"82\">Drought Forecast</h4>\n          </div>\n          <p class=\"text-sm text-slate-400 leading-relaxed mb-6\" data-kid=\"83\">\n            Predictive modeling of rainfall deficit, heat anomalies, and vegetation health conditions.\n          </p>\n          <span class=\"inline-flex items-center rounded-full bg-emerald-400/10 px-3 py-1 text-xs font-semibold text-emerald-300 border border-emerald-400/20\" data-kid=\"84\">\n            XGBoostDrought-v1\n          </span>\n        </div>\n\n        \n        <div class=\"p-6 rounded-xl bg-slate-900/40 border border-white/5 hover:border-rose-400/20 transition-all\" data-kid=\"85\">\n          <div class=\"flex items-center gap-3 mb-4\" data-kid=\"86\">\n            <div class=\"w-10 h-10 rounded-lg bg-rose-400/10 flex items-center justify-center text-rose-400 border border-rose-400/20\" data-kid=\"87\">\n              <i data-lucide=\"sun\" class=\"w-5 h-5\" data-kid=\"88\"></i>\n            </div>\n            <h4 class=\"font-semibold text-white\" data-kid=\"89\">Heatwave Forecast</h4>\n          </div>\n          <p class=\"text-sm text-slate-400 leading-relaxed mb-6\" data-kid=\"90\">\n            Trend analysis for extreme temperature events and atmospheric humidity stress levels.\n          </p>\n          <span class=\"inline-flex items-center rounded-full bg-rose-400/10 px-3 py-1 text-xs font-semibold text-rose-300 border border-rose-400/20\" data-kid=\"91\">\n            SklearnHeatAlert-v1\n          </span>\n        </div>\n      </div>\n    </div>\n  </div>\n</main>\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"92\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"93\"></script>\n\n<script data-kid=\"94\">\n  lucide.createIcons();\n\n  const generateData = (count, min, max) => {\n    return Array.from({length: count}, () => Math.floor(Math.random() * (max - min + 1) + min));\n  };\n\n  const chartConfig = (color, data, label, unit = '') => ({\n    type: 'line',\n    data: {\n      labels: Array.from({length: 36}, (_, i) => i + 1),\n      datasets: [{\n        label: label,\n        data: data,\n        borderColor: color,\n        backgroundColor: color + '20',\n        borderWidth: 2,\n        fill: true,\n        tension: 0.4,\n        pointRadius: 0,\n        pointHoverRadius: 4,\n      }]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: {\n        legend: { display: false }\n      },\n      scales: {\n        x: { display: false },\n        y: {\n          grid: { color: 'rgba(255, 255, 255, 0.05)' },\n          ticks: { \n            color: '#64748b',\n            font: { size: 10 },\n            callback: (value) => value + unit\n          }\n        }\n      }\n    }\n  });\n\n  new Chart(document.getElementById('tempChart'), chartConfig('#f87171', generateData(36, 24, 32), 'Temp', '°C'));\n  new Chart(document.getElementById('rainChart'), chartConfig('#22d3ee', generateData(36, 10, 300), 'Rain', 'mm'));\n  new Chart(document.getElementById('reservoirChart'), chartConfig('#10b981', generateData(36, 40, 95), 'Reservoir', '%'));\n  new Chart(document.getElementById('aqiChart'), chartConfig('#fbbf24', generateData(36, 80, 250), 'AQI'));\n</script>",
