      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n\n  :root {\n    --background: #020617;\n    --foreground: #eefafc;\n    --primary: #06b6d4;\n    --secondary: #22c55e;\n    --accent: #fbbf24;\n    --card: rgba(16, 22, 32, 0.8);\n    --border: rgba(6, 182, 212, 0.2);\n  }\n\n  body {\n    margin: 0;\n    font-family: 'Inter', sans-serif;\n    color: var(--foreground);\n    background-color: var(--background);\n  }\n\n  .radar-grid {\n    background-image: \n      linear-gradient(var(--border) 1px, transparent 1px),\n      linear-gradient(90deg, var(--border) 1px, transparent 1px);\n    background-size: 40px 40px;\n    background-position: center;\n  }\n\n  .glass-panel {\n    border: 1px solid var(--border);\n    background: rgba(8, 20, 34, 0.6);\n    backdrop-filter: blur(12px);\n    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);\n  }\n\n  .shadow-glow {\n    box-shadow: 0 0 30px rgba(6, 182, 212, 0.15);\n  }\n\n  .step-node {\n    transition: all 0.3s ease;\n  }\n\n  .step-node:hover {\n    border-color: var(--primary);\n    transform: translateY(-4px);\n    box-shadow: 0 0 40px rgba(6, 182, 212, 0.25);\n  }\n\n  @keyframes pulse-line {\n    0% { stroke-dashoffset: 100; opacity: 0.3; }\n    50% { opacity: 0.8; }\n    100% { stroke-dashoffset: 0; opacity: 0.3; }\n  }\n\n  .flow-line {\n    stroke-dasharray: 10, 5;\n    animation: pulse-line 4s linear infinite;\n  }\n</style>\n\n<main class=\"min-h-screen p-8 lg:p-20 space-y-16 radar-grid relative overflow-hidden\" data-kid=\"1\">\n  \n  \n  <div class=\"max-w-4xl space-y-6 relative z-10\" data-kid=\"2\">\n    <div class=\"inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-primary backdrop-blur-md\" data-kid=\"3\">\n      <i data-lucide=\"cpu\" class=\"w-4 h-4\" data-kid=\"4\"></i>\n      Core AI Architecture\n    </div>\n    <h1 class=\"text-5xl lg:text-7xl font-bold tracking-tight text-white leading-tight\" data-kid=\"5\">\n      Climate Digital Twin <span class=\"text-primary\" data-kid=\"6\">Workflow</span>\n    </h1>\n    <p class=\"text-xl text-slate-400 max-w-2xl leading-relaxed\" data-kid=\"7\">\n      The end-to-end technical pipeline integrating multi-source national observation datasets into a predictive \"What-If\" climate simulation engine.\n    </p>\n  </div>\n\n  \n  <div class=\"relative py-12\" data-kid=\"8\">\n    \n    <svg class=\"absolute inset-0 w-full h-full pointer-events-none hidden md:block opacity-40\" style=\"z-index: 0;\" data-kid=\"9\">\n      <path d=\"M 12.5% 120 L 87.5% 120\" stroke=\"url(#cyan-grad)\" stroke-width=\"2\" fill=\"none\" class=\"flow-line\" data-kid=\"10\"></path>\n      <path d=\"M 87.5% 120 L 87.5% 320\" stroke=\"url(#cyan-grad)\" stroke-width=\"2\" fill=\"none\" class=\"flow-line\" data-kid=\"11\"></path>\n      <path d=\"M 87.5% 320 L 12.5% 320\" stroke=\"url(#cyan-grad)\" stroke-width=\"2\" fill=\"none\" class=\"flow-line\" data-kid=\"12\"></path>\n      \n      <defs data-kid=\"13\">\n        <linearGradient id=\"cyan-grad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\" data-kid=\"14\">\n          <stop offset=\"0%\" style=\"stop-color:var(--primary);stop-opacity:1\" data-kid=\"15\"></stop>\n          <stop offset=\"100%\" style=\"stop-color:var(--secondary);stop-opacity:1\" data-kid=\"16\"></stop>\n        </linearGradient>\n      </defs>\n    </svg>\n\n    \n    <div class=\"grid grid-cols-1 md:grid-cols-4 gap-8 relative z-10 mb-24\" data-kid=\"17\">\n      <div class=\"glass-panel p-8 rounded-2xl text-center space-y-4 step-node shadow-glow\" data-kid=\"18\">\n        <div class=\"w-14 h-14 mx-auto rounded-xl bg-primary/20 flex items-center justify-center text-primary border border-primary/40\" data-kid=\"19\">\n          <i data-lucide=\"target\" class=\"w-7 h-7\" data-kid=\"20\"></i>\n        </div>\n        <div data-kid=\"21\">\n          <h3 class=\"font-bold text-white text-lg\" data-kid=\"22\">Problem Definition</h3>\n          <p class=\"text-xs text-slate-400 mt-2\" data-kid=\"23\">Pilot Region & Variable Selection</p>\n        </div>\n      </div>\n\n      <div class=\"glass-panel p-8 rounded-2xl text-center space-y-4 step-node shadow-glow\" data-kid=\"24\">\n        <div class=\"w-14 h-14 mx-auto rounded-xl bg-primary/20 flex items-center justify-center text-primary border border-primary/40\" data-kid=\"25\">\n          <i data-lucide=\"database\" class=\"w-7 h-7\" data-kid=\"26\"></i>\n        </div>\n        <div data-kid=\"27\">\n          <h3 class=\"font-bold text-white text-lg\" data-kid=\"28\">Data Collection</h3>\n          <p class=\"text-xs text-slate-400 mt-2\" data-kid=\"29\">IMD Gridded & INSAT Products</p>\n        </div>\n      </div>\n\n      <div class=\"glass-panel p-8 rounded-2xl text-center space-y-4 step-node shadow-glow\" data-kid=\"30\">\n        <div class=\"w-14 h-14 mx-auto rounded-xl bg-primary/20 flex items-center justify-center text-primary border border-primary/40\" data-kid=\"31\">\n          <i data-lucide=\"layers\" class=\"w-7 h-7\" data-kid=\"32\"></i>\n        </div>\n        <div data-kid=\"33\">\n          <h3 class=\"font-bold text-white text-lg\" data-kid=\"34\">Data Processing</h3>\n          <p class=\"text-xs text-slate-400 mt-2\" data-kid=\"35\">Feature Engineering & QC</p>\n        </div>\n      </div>\n\n      <div class=\"glass-panel p-8 rounded-2xl text-center space-y-4 step-node border-secondary/40 shadow-[0_0_40px_rgba(34,197,94,0.15)]\" data-kid=\"36\">\n        <div class=\"w-14 h-14 mx-auto rounded-xl bg-secondary/20 flex items-center justify-center text-secondary border border-secondary/40\" data-kid=\"37\">\n          <i data-lucide=\"brain-circuit\" class=\"w-7 h-7\" data-kid=\"38\"></i>\n        </div>\n        <div data-kid=\"39\">\n          <h3 class=\"font-bold text-white text-lg text-secondary\" data-kid=\"40\">Model Development</h3>\n          <p class=\"text-xs text-slate-400 mt-2\" data-kid=\"41\">Training (LSTM/Transformer)</p>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"grid grid-cols-1 md:grid-cols-4 gap-8 relative z-10\" data-kid=\"42\">\n      <div class=\"glass-panel p-8 rounded-2xl text-center space-y-4 step-node shadow-glow md:order-4\" data-kid=\"43\">\n        <div class=\"w-14 h-14 mx-auto rounded-xl bg-primary/20 flex items-center justify-center text-primary border border-primary/40\" data-kid=\"44\">\n          <i data-lucide=\"sliders\" class=\"w-7 h-7\" data-kid=\"45\"></i>\n        </div>\n        <div data-kid=\"46\">\n          <h3 class=\"font-bold text-white text-lg\" data-kid=\"47\">Scenario Analysis</h3>\n          <p class=\"text-xs text-slate-400 mt-2\" data-kid=\"48\">What-if Climate Simulator</p>\n        </div>\n      </div>\n\n      <div class=\"glass-panel p-8 rounded-2xl text-center space-y-4 step-node shadow-glow md:order-3\" data-kid=\"49\">\n        <div class=\"w-14 h-14 mx-auto rounded-xl bg-primary/20 flex items-center justify-center text-primary border border-primary/40\" data-kid=\"50\">\n          <i data-lucide=\"map\" class=\"w-7 h-7\" data-kid=\"51\"></i>\n        </div>\n        <div data-kid=\"52\">\n          <h3 class=\"font-bold text-white text-lg\" data-kid=\"53\">Visualization</h3>\n          <p class=\"text-xs text-slate-400 mt-2\" data-kid=\"54\">Interactive GIS Dashboard</p>\n        </div>\n      </div>\n\n      <div class=\"glass-panel p-8 rounded-2xl text-center space-y-4 step-node shadow-glow md:order-2\" data-kid=\"55\">\n        <div class=\"w-14 h-14 mx-auto rounded-xl bg-primary/20 flex items-center justify-center text-primary border border-primary/40\" data-kid=\"56\">\n          <i data-lucide=\"check-circle-2\" class=\"w-7 h-7\" data-kid=\"57\"></i>\n        </div>\n        <div data-kid=\"58\">\n          <h3 class=\"font-bold text-white text-lg\" data-kid=\"59\">Training & Validation</h3>\n          <p class=\"text-xs text-slate-400 mt-2\" data-kid=\"60\">Actual vs Predicted Analysis</p>\n        </div>\n      </div>\n\n      <div class=\"glass-panel p-8 rounded-2xl text-center space-y-4 step-node border-secondary/40 shadow-[0_0_40px_rgba(34,197,94,0.15)] md:order-1\" data-kid=\"61\">\n        <div class=\"w-14 h-14 mx-auto rounded-xl bg-secondary/20 flex items-center justify-center text-secondary border border-secondary/40\" data-kid=\"62\">\n          <i data-lucide=\"gemini\" class=\"w-7 h-7\" data-kid=\"63\"></i>\n        </div>\n        <div data-kid=\"64\">\n          <h3 class=\"font-bold text-white text-lg text-secondary\" data-kid=\"65\">Digital Twin Engine</h3>\n          <p class=\"text-xs text-slate-400 mt-2\" data-kid=\"66\">High-Fidelity Virtual State</p>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-8 pt-12\" data-kid=\"67\">\n    \n    <div class=\"glass-panel p-10 rounded-3xl space-y-8\" data-kid=\"68\">\n      <div class=\"flex items-center gap-3\" data-kid=\"69\">\n        <i data-lucide=\"log-in\" class=\"w-6 h-6 text-primary\" data-kid=\"70\"></i>\n        <h2 class=\"text-2xl font-bold text-white\" data-kid=\"71\">Observational Inputs</h2>\n      </div>\n      <div class=\"space-y-4\" data-kid=\"72\">\n        <div class=\"p-4 rounded-xl bg-white/5 border border-white/10 flex justify-between items-center\" data-kid=\"73\">\n          <span class=\"text-slate-300 font-medium\" data-kid=\"74\">IMD Rainfall</span>\n          <span class=\"text-[10px] px-2 py-1 rounded bg-primary/10 text-primary border border-primary/20\" data-kid=\"75\">0.25° Gridded</span>\n        </div>\n        <div class=\"p-4 rounded-xl bg-white/5 border border-white/10 flex justify-between items-center\" data-kid=\"76\">\n          <span class=\"text-slate-300 font-medium\" data-kid=\"77\">IMD Temperature</span>\n          <span class=\"text-[10px] px-2 py-1 rounded bg-primary/10 text-primary border border-primary/20\" data-kid=\"78\">1.0° Gridded</span>\n        </div>\n        <div class=\"p-4 rounded-xl bg-white/5 border border-white/10 flex justify-between items-center\" data-kid=\"79\">\n          <span class=\"text-slate-300 font-medium\" data-kid=\"80\">INSAT-3D LST</span>\n          <span class=\"text-[10px] px-2 py-1 rounded bg-primary/10 text-primary border border-primary/20\" data-kid=\"81\">Satellite</span>\n        </div>\n        <div class=\"p-4 rounded-xl bg-white/5 border border-white/10 flex justify-between items-center\" data-kid=\"82\">\n          <span class=\"text-slate-300 font-medium\" data-kid=\"83\">INSAT-3R SST</span>\n          <span class=\"text-[10px] px-2 py-1 rounded bg-primary/10 text-primary border border-primary/20\" data-kid=\"84\">Satellite</span>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"glass-panel p-10 rounded-3xl space-y-8 border-secondary/30\" data-kid=\"85\">\n      <div class=\"flex items-center gap-3\" data-kid=\"86\">\n        <i data-lucide=\"brain\" class=\"w-6 h-6 text-secondary\" data-kid=\"87\"></i>\n        <h2 class=\"text-2xl font-bold text-white\" data-kid=\"88\">AI Engine Stack</h2>\n      </div>\n      <div class=\"space-y-6\" data-kid=\"89\">\n        <div data-kid=\"90\">\n          <h4 class=\"text-secondary font-bold text-sm uppercase tracking-widest\" data-kid=\"91\">LSTM / GRU</h4>\n          <p class=\"text-sm text-slate-400 mt-2 leading-relaxed\" data-kid=\"92\">Specialized in capturing long-term temporal dependencies in Indian monsoon rainfall patterns.</p>\n        </div>\n        <div class=\"h-px bg-white/10\" data-kid=\"93\"></div>\n        <div data-kid=\"94\">\n          <h4 class=\"text-secondary font-bold text-sm uppercase tracking-widest\" data-kid=\"95\">Transformer Units</h4>\n          <p class=\"text-sm text-slate-400 mt-2 leading-relaxed\" data-kid=\"96\">Multi-head attention mechanisms for multi-scale spatial data fusion and extreme heatwave prediction.</p>\n        </div>\n        <div class=\"h-px bg-white/10\" data-kid=\"97\"></div>\n        <div data-kid=\"98\">\n          <h4 class=\"text-secondary font-bold text-sm uppercase tracking-widest\" data-kid=\"99\">CNN-LSTM Hybrid</h4>\n          <p class=\"text-sm text-slate-400 mt-2 leading-relaxed\" data-kid=\"100\">Spatio-temporal feature extraction from complex satellite raster datasets and ground stations.</p>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"glass-panel p-10 rounded-3xl space-y-8\" data-kid=\"101\">\n      <div class=\"flex items-center gap-3\" data-kid=\"102\">\n        <i data-lucide=\"zap\" class=\"w-6 h-6 text-accent\" data-kid=\"103\"></i>\n        <h2 class=\"text-2xl font-bold text-white\" data-kid=\"104\">Platform Outcomes</h2>\n      </div>\n      <div class=\"grid grid-cols-2 gap-4\" data-kid=\"105\">\n        <div class=\"p-6 rounded-2xl bg-accent/5 border border-accent/20 text-center\" data-kid=\"106\">\n          <div class=\"text-3xl font-bold text-white\" data-kid=\"107\">92.4%</div>\n          <div class=\"text-[10px] uppercase tracking-widest text-accent mt-2\" data-kid=\"108\">Accuracy</div>\n        </div>\n        <div class=\"p-6 rounded-2xl bg-accent/5 border border-accent/20 text-center\" data-kid=\"109\">\n          <div class=\"text-3xl font-bold text-white\" data-kid=\"110\">< 2mm</div>\n          <div class=\"text-[10px] uppercase tracking-widest text-accent mt-2\" data-kid=\"111\">Rain MAE</div>\n        </div>\n      </div>\n      <div class=\"space-y-4\" data-kid=\"112\">\n        <div class=\"flex items-center gap-3 text-slate-300\" data-kid=\"113\">\n          <i data-lucide=\"verified\" class=\"w-5 h-5 text-accent/60\" data-kid=\"114\"></i>\n          Short-term Rainfall Forecasts\n        </div>\n        <div class=\"flex items-center gap-3 text-slate-300\" data-kid=\"115\">\n          <i data-lucide=\"verified\" class=\"w-5 h-5 text-accent/60\" data-kid=\"116\"></i>\n          District Risk Assessment Scores\n        </div>\n        <div class=\"flex items-center gap-3 text-slate-300\" data-kid=\"117\">\n          <i data-lucide=\"verified\" class=\"w-5 h-5 text-accent/60\" data-kid=\"118\"></i>\n          Agricultural Stress Visualization\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"pt-12 border-t border-white/5\" data-kid=\"119\">\n    <div class=\"grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-12 opacity-40 grayscale hover:grayscale-0 transition-all duration-500 items-center\" data-kid=\"120\">\n      <img src=\"https://upload.wikimedia.org/wikipedia/commons/1/10/PyTorch_logo_icon.svg\" class=\"h-10 mx-auto\" alt=\"PyTorch\" data-kid=\"121\">\n      <img src=\"https://upload.wikimedia.org/wikipedia/commons/2/2d/Tensorflow_logo.svg\" class=\"h-10 mx-auto\" alt=\"TensorFlow\" data-kid=\"122\">\n      <img src=\"https://upload.wikimedia.org/wikipedia/commons/0/05/Scikit_learn_logo_small.svg\" class=\"h-12 mx-auto\" alt=\"Scikit-learn\" data-kid=\"123\">\n      <img src=\"https://upload.wikimedia.org/wikipedia/commons/3/31/NumPy_logo_2020.svg\" class=\"h-10 mx-auto\" alt=\"NumPy\" data-kid=\"124\">\n      <img src=\"https://upload.wikimedia.org/wikipedia/commons/4/4b/Pandas_logo.svg\" class=\"h-10 mx-auto\" alt=\"Pandas\" data-kid=\"125\">\n      <img src=\"https://upload.wikimedia.org/wikipedia/commons/c/c3/Python-logo-notext.svg\" class=\"h-10 mx-auto\" alt=\"Python\" data-kid=\"126\">\n    </div>\n  </div>\n</main>\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"127\"></script>\n<script data-kid=\"128\">\n  lucide.createIcons();\n</script>",
