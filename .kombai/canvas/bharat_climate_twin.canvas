      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n\n  :root {\n    --bg-main: #020617;\n    --card-bg: rgba(15, 23, 42, 0.6);\n    --cyan-accent: #06b6d4;\n    --emerald-accent: #10b981;\n    --amber-accent: #fbbf24;\n    --rose-accent: #f43f5e;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: var(--bg-main);\n    color: #f8fafc;\n    margin: 0;\n  }\n\n  .radar-grid {\n    background-image: radial-gradient(circle at 1px 1px, rgba(34, 211, 238, 0.05) 1px, transparent 0);\n    background-size: 24px 24px;\n  }\n\n  .glass-card {\n    background: rgba(15, 23, 42, 0.4);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(34, 211, 238, 0.15);\n  }\n\n  .glow-cyan {\n    box-shadow: 0 0 20px rgba(6, 182, 212, 0.15);\n  }\n\n  .scanline {\n    position: relative;\n    overflow: hidden;\n  }\n  .scanline::after {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(to bottom, transparent 50%, rgba(34, 211, 238, 0.02) 50%);\n    background-size: 100% 4px;\n    pointer-events: none;\n  }\n\n  /* Custom Gauge Styles */\n  .gauge-container {\n    position: relative;\n    width: 240px;\n    height: 120px;\n    overflow: hidden;\n  }\n  .gauge-path {\n    fill: none;\n    stroke: rgba(255, 255, 255, 0.1);\n    stroke-width: 12;\n    stroke-linecap: round;\n  }\n  .gauge-fill {\n    fill: none;\n    stroke: var(--cyan-accent);\n    stroke-width: 12;\n    stroke-linecap: round;\n    stroke-dasharray: 314;\n    stroke-dashoffset: 125; /* Represents ~60% */\n    transition: stroke-dashoffset 1s ease-out;\n  }\n</style>\n\n<main class=\"min-h-screen p-8 lg:p-12 radar-grid scanline\" data-kid=\"1\">\n  \n  <header class=\"flex flex-col xl:flex-row justify-between items-start xl:items-end gap-6 mb-10\" data-kid=\"2\">\n    <div data-kid=\"3\">\n      <div class=\"inline-flex items-center gap-2 rounded-md border border-cyan-400/30 bg-cyan-400/10 px-3 py-1.5 text-sm font-medium text-cyan-200\" data-kid=\"4\">\n        <i data-lucide=\"shield-alert\" class=\"w-4 h-4\" data-kid=\"5\"></i>\n        Climate Risk Engine\n      </div>\n      <h1 class=\"mt-4 text-4xl font-bold tracking-tight text-white\" data-kid=\"6\">District Risk Center</h1>\n      <p class=\"mt-2 text-slate-400 max-w-2xl text-lg\" data-kid=\"7\">\n        Transparent 0-100 scoring for flood, drought, heatwave, and water stress with multi-hazard trend analytics.\n      </p>\n    </div>\n    \n    <div class=\"w-full max-w-md\" data-kid=\"8\">\n      <div class=\"relative\" data-kid=\"9\">\n        <div class=\"absolute inset-y-0 left-3 flex items-center pointer-events-none\" data-kid=\"10\">\n          <i data-lucide=\"search\" class=\"w-4 h-4 text-slate-500\" data-kid=\"11\"></i>\n        </div>\n        <input type=\"text\" placeholder=\"Search District (e.g. Kutch, Gujarat)\" class=\"w-full bg-slate-900/50 border border-slate-700 rounded-lg py-3 pl-10 pr-4 text-white focus:outline-none focus:border-cyan-400/50 transition-all\" data-kid=\"12\">\n      </div>\n    </div>\n  </header>\n\n  \n  <div class=\"grid grid-cols-1 xl:grid-cols-[0.75fr_1.25fr] gap-6 mb-8\" data-kid=\"13\">\n    \n    \n    <div class=\"glass-card rounded-2xl p-8 flex flex-col items-center gap-8\" data-kid=\"14\">\n      <div class=\"text-center\" data-kid=\"15\">\n        <h3 class=\"text-2xl font-bold text-white\" data-kid=\"16\">Kutch</h3>\n        <p class=\"text-slate-400 text-sm\" data-kid=\"17\">Gujarat • Latest climate risk profile</p>\n      </div>\n\n      <div class=\"flex flex-col items-center\" data-kid=\"18\">\n        <div class=\"gauge-container\" data-kid=\"19\">\n          <svg viewBox=\"0 0 100 50\" class=\"w-full h-full\" data-kid=\"20\">\n            <path d=\"M 10 45 A 35 35 0 0 1 90 45\" class=\"gauge-path\" data-kid=\"21\"></path>\n            <path d=\"M 10 45 A 35 35 0 0 1 90 45\" class=\"gauge-fill\" style=\"stroke-dashoffset: 70;\" data-kid=\"22\"></path>\n          </svg>\n          <div class=\"absolute inset-0 flex flex-col items-center justify-end pb-2\" data-kid=\"23\">\n            <span class=\"text-4xl font-bold text-white\" data-kid=\"24\">78</span>\n            <span class=\"text-[10px] uppercase tracking-widest text-rose-400 font-bold\" data-kid=\"25\">High Risk</span>\n          </div>\n        </div>\n        <p class=\"mt-4 text-sm font-medium text-slate-300\" data-kid=\"26\">Composite Climate Risk</p>\n      </div>\n\n      <div class=\"grid grid-cols-2 gap-3 w-full\" data-kid=\"27\">\n        <div class=\"bg-white/5 border border-white/10 rounded-xl p-4\" data-kid=\"28\">\n          <p class=\"text-xs text-slate-500 mb-1\" data-kid=\"29\">Flood</p>\n          <p class=\"text-2xl font-bold text-emerald-400\" data-kid=\"30\">12</p>\n        </div>\n        <div class=\"bg-white/5 border border-white/10 rounded-xl p-4\" data-kid=\"31\">\n          <p class=\"text-xs text-slate-500 mb-1\" data-kid=\"32\">Drought</p>\n          <p class=\"text-2xl font-bold text-rose-400\" data-kid=\"33\">84</p>\n        </div>\n        <div class=\"bg-white/5 border border-white/10 rounded-xl p-4\" data-kid=\"34\">\n          <p class=\"text-xs text-slate-500 mb-1\" data-kid=\"35\">Heatwave</p>\n          <p class=\"text-2xl font-bold text-amber-400\" data-kid=\"36\">65</p>\n        </div>\n        <div class=\"bg-white/5 border border-white/10 rounded-xl p-4\" data-kid=\"37\">\n          <p class=\"text-xs text-slate-500 mb-1\" data-kid=\"38\">Water Stress</p>\n          <p class=\"text-2xl font-bold text-rose-400\" data-kid=\"39\">92</p>\n        </div>\n      </div>\n\n      <button class=\"w-full flex items-center justify-center gap-2 border border-slate-700 hover:bg-slate-800 text-white font-medium py-3 rounded-xl transition-all\" data-kid=\"40\">\n        <i data-lucide=\"download\" class=\"w-4 h-4\" data-kid=\"41\"></i>\n        Export PDF Report\n      </button>\n    </div>\n\n    \n    <div class=\"glass-card rounded-2xl p-8\" data-kid=\"42\">\n      <div class=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8\" data-kid=\"43\">\n        <div data-kid=\"44\">\n          <h3 class=\"text-xl font-bold text-white\" data-kid=\"45\">Risk Trend Graphs</h3>\n          <p class=\"text-sm text-slate-400\" data-kid=\"46\">Multi-hazard monthly trajectory for early warning</p>\n        </div>\n        <div class=\"flex gap-2\" data-kid=\"47\">\n          <span class=\"flex items-center gap-1.5 text-xs text-slate-300 px-2 py-1 rounded bg-white/5 border border-white/10\" data-kid=\"48\">\n            <span class=\"w-2 h-2 rounded-full bg-cyan-400\" data-kid=\"49\"></span> Flood\n          </span>\n          <span class=\"flex items-center gap-1.5 text-xs text-slate-300 px-2 py-1 rounded bg-white/5 border border-white/10\" data-kid=\"50\">\n            <span class=\"w-2 h-2 rounded-full bg-rose-400\" data-kid=\"51\"></span> Drought\n          </span>\n        </div>\n      </div>\n      \n      <div class=\"h-[400px] w-full\" data-kid=\"52\">\n        <canvas id=\"riskTrendChart\" data-kid=\"53\"></canvas>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"glass-card rounded-2xl p-8\" data-kid=\"54\">\n    <div class=\"mb-8\" data-kid=\"55\">\n      <h3 class=\"text-xl font-bold text-white\" data-kid=\"56\">Climate Vulnerability Leaderboard</h3>\n      <p class=\"text-sm text-slate-400\" data-kid=\"57\">Highest composite district scores across national monitored zones</p>\n    </div>\n\n    <div class=\"overflow-x-auto\" data-kid=\"58\">\n      <table class=\"w-full text-left border-collapse\" data-kid=\"59\">\n        <thead data-kid=\"60\">\n          <tr class=\"border-b border-white/10 text-slate-500 text-xs uppercase tracking-wider\" data-kid=\"61\">\n            <th class=\"pb-4 font-semibold\" data-kid=\"62\">District</th>\n            <th class=\"pb-4 font-semibold\" data-kid=\"63\">State</th>\n            <th class=\"pb-4 font-semibold\" data-kid=\"64\">Composite</th>\n            <th class=\"pb-4 font-semibold\" data-kid=\"65\">Flood</th>\n            <th class=\"pb-4 font-semibold\" data-kid=\"66\">Drought</th>\n            <th class=\"pb-4 font-semibold\" data-kid=\"67\">Heatwave</th>\n            <th class=\"pb-4 font-semibold\" data-kid=\"68\">Trend</th>\n          </tr>\n        </thead>\n        <tbody class=\"text-sm\" data-kid=\"69\">\n          <tr class=\"border-b border-white/5 hover:bg-white/5 transition-colors\" data-kid=\"70\">\n            <td class=\"py-5 font-bold text-white\" data-kid=\"71\">Kutch</td>\n            <td class=\"text-slate-400\" data-kid=\"72\">Gujarat</td>\n            <td class=\"font-bold text-rose-400\" data-kid=\"73\">78</td>\n            <td class=\"text-emerald-400\" data-kid=\"74\">12</td>\n            <td class=\"text-rose-400\" data-kid=\"75\">84</td>\n            <td class=\"text-amber-400\" data-kid=\"76\">65</td>\n            <td data-kid=\"77\"><span class=\"px-2 py-0.5 rounded-full bg-rose-400/10 text-rose-400 text-[10px] font-bold border border-rose-400/20\" data-kid=\"78\">Increasing</span></td>\n          </tr>\n          <tr class=\"border-b border-white/5 hover:bg-white/5 transition-colors\" data-kid=\"79\">\n            <td class=\"py-5 font-bold text-white\" data-kid=\"80\">Jaisalmer</td>\n            <td class=\"text-slate-400\" data-kid=\"81\">Rajasthan</td>\n            <td class=\"font-bold text-rose-400\" data-kid=\"82\">76</td>\n            <td class=\"text-emerald-400\" data-kid=\"83\">08</td>\n            <td class=\"text-rose-400\" data-kid=\"84\">92</td>\n            <td class=\"text-rose-400\" data-kid=\"85\">88</td>\n            <td data-kid=\"86\"><span class=\"px-2 py-0.5 rounded-full bg-slate-400/10 text-slate-400 text-[10px] font-bold border border-white/10\" data-kid=\"87\">Stable</span></td>\n          </tr>\n          <tr class=\"border-b border-white/5 hover:bg-white/5 transition-colors\" data-kid=\"88\">\n            <td class=\"py-5 font-bold text-white\" data-kid=\"89\">Dibrugarh</td>\n            <td class=\"text-slate-400\" data-kid=\"90\">Assam</td>\n            <td class=\"font-bold text-amber-400\" data-kid=\"91\">72</td>\n            <td class=\"text-rose-400\" data-kid=\"92\">95</td>\n            <td class=\"text-emerald-400\" data-kid=\"93\">14</td>\n            <td class=\"text-emerald-400\" data-kid=\"94\">22</td>\n            <td data-kid=\"95\"><span class=\"px-2 py-0.5 rounded-full bg-rose-400/10 text-rose-400 text-[10px] font-bold border border-rose-400/20\" data-kid=\"96\">Increasing</span></td>\n          </tr>\n          <tr class=\"border-b border-white/5 hover:bg-white/5 transition-colors\" data-kid=\"97\">\n            <td class=\"py-5 font-bold text-white\" data-kid=\"98\">Leh</td>\n            <td class=\"text-slate-400\" data-kid=\"99\">Ladakh</td>\n            <td class=\"font-bold text-amber-400\" data-kid=\"100\">64</td>\n            <td class=\"text-emerald-400\" data-kid=\"101\">05</td>\n            <td class=\"text-amber-400\" data-kid=\"102\">68</td>\n            <td class=\"text-emerald-400\" data-kid=\"103\">12</td>\n            <td data-kid=\"104\"><span class=\"px-2 py-0.5 rounded-full bg-emerald-400/10 text-emerald-400 text-[10px] font-bold border border-emerald-400/20\" data-kid=\"105\">Decreasing</span></td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n</main>\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"106\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"107\"></script>\n<script data-kid=\"108\">\n  lucide.createIcons();\n\n  const ctx = document.getElementById('riskTrendChart').getContext('2d');\n  new Chart(ctx, {\n    type: 'line',\n    data: {\n      labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],\n      datasets: [\n        {\n          label: 'Drought Risk',\n          data: [65, 68, 72, 80, 84, 86, 82, 78, 75, 76, 78, 80],\n          borderColor: '#f43f5e',\n          backgroundColor: 'rgba(244, 63, 94, 0.1)',\n          fill: true,\n          tension: 0.4,\n          borderWidth: 2,\n          pointRadius: 0,\n        },\n        {\n          label: 'Flood Risk',\n          data: [10, 12, 11, 15, 14, 25, 45, 60, 40, 20, 15, 12],\n          borderColor: '#06b6d4',\n          backgroundColor: 'rgba(6, 182, 212, 0.1)',\n          fill: true,\n          tension: 0.4,\n          borderWidth: 2,\n          pointRadius: 0,\n        }\n      ]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: {\n        legend: { display: false }\n      },\n      scales: {\n        y: {\n          beginAtZero: true,\n          grid: { color: 'rgba(255, 255, 255, 0.05)' },\n          ticks: { color: '#94a3b8', font: { size: 10 } }\n        },\n        x: {\n          grid: { display: false },\n          ticks: { color: '#94a3b8', font: { size: 10 } }\n        }\n      }\n    }\n  });\n</script>",
