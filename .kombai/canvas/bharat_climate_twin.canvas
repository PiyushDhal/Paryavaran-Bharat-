      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n\n  :root {\n    --bg-main: #020617;\n    --card-bg: rgba(15, 23, 42, 0.4);\n    --cyan-primary: #06b6d4;\n    --cyan-glow: rgba(6, 182, 212, 0.15);\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: var(--bg-main);\n    color: #f8fafc;\n    margin: 0;\n  }\n\n  .radar-grid {\n    background-image: radial-gradient(circle at 1px 1px, rgba(34, 211, 238, 0.05) 1px, transparent 0);\n    background-size: 24px 24px;\n  }\n\n  .glass-card {\n    background: var(--card-bg);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(34, 211, 238, 0.15);\n  }\n\n  .scanline {\n    position: relative;\n    overflow: hidden;\n  }\n  .scanline::after {\n    content: \"\";\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background: linear-gradient(to bottom, transparent 50%, rgba(34, 211, 238, 0.02) 50%);\n    background-size: 100% 4px;\n    pointer-events: none;\n  }\n\n  input[type=\"range\"] {\n    -webkit-appearance: none;\n    background: rgba(34, 211, 238, 0.1);\n    height: 6px;\n    border-radius: 3px;\n    outline: none;\n  }\n\n  input[type=\"range\"]::-webkit-slider-thumb {\n    -webkit-appearance: none;\n    width: 16px;\n    height: 16px;\n    background: var(--cyan-primary);\n    border-radius: 50%;\n    cursor: pointer;\n    box-shadow: 0 0 10px var(--cyan-glow);\n  }\n</style>\n\n<main class=\"min-h-screen p-6 lg:p-12 radar-grid\" data-kid=\"1\">\n  <div class=\"max-w-7xl mx-auto space-y-8\" data-kid=\"2\">\n    \n    \n    <div class=\"space-y-3\" data-kid=\"3\">\n      <div class=\"inline-flex items-center gap-2 rounded-md border border-cyan-400/20 bg-cyan-400/10 px-3 py-1 text-xs font-semibold text-cyan-200\" data-kid=\"4\">\n        Climate Scenario Simulator\n      </div>\n      <h1 class=\"text-4xl font-bold tracking-tight text-white\" data-kid=\"5\">Future Conditions Lab</h1>\n      <p class=\"max-w-3xl text-slate-400 leading-relaxed\" data-kid=\"6\">\n        Adjust rainfall, temperature, and reservoir capacity to recalculate water availability, crop stress, drought, heatwave, and composite climate risk.\n      </p>\n    </div>\n\n    \n    <div class=\"grid grid-cols-1 xl:grid-cols-[0.9fr_1.1fr] gap-6 items-start\" data-kid=\"7\">\n      \n      \n      <div class=\"glass-card rounded-2xl overflow-hidden shadow-2xl\" data-kid=\"8\">\n        <div class=\"p-6 border-b border-cyan-400/10\" data-kid=\"9\">\n          <h2 class=\"text-xl font-bold text-white\" data-kid=\"10\">Scenario Inputs</h2>\n          <p class=\"text-sm text-slate-400 mt-1\" data-kid=\"11\">Sliders model plausible policy and climate stress conditions.</p>\n        </div>\n        \n        <div class=\"p-8 space-y-8\" data-kid=\"12\">\n          \n          <div class=\"space-y-3\" data-kid=\"13\">\n            <label class=\"text-sm font-medium text-slate-300\" data-kid=\"14\">Target District</label>\n            <div class=\"w-full bg-slate-900/50 border border-slate-700 rounded-lg px-4 py-3 flex justify-between items-center text-slate-200\" data-kid=\"15\">\n              <span data-kid=\"16\">Bengaluru Urban, Karnataka</span>\n              <i data-lucide=\"chevron-down\" class=\"w-4 h-4\" data-kid=\"17\"></i>\n            </div>\n          </div>\n\n          \n          <div class=\"space-y-6\" data-kid=\"18\">\n            <div class=\"space-y-4\" data-kid=\"19\">\n              <div class=\"flex justify-between items-end\" data-kid=\"20\">\n                <label class=\"text-sm font-medium text-slate-300\" data-kid=\"21\">Rainfall change</label>\n                <span class=\"text-cyan-400 font-mono font-bold\" data-kid=\"22\">-20%</span>\n              </div>\n              <input type=\"range\" min=\"-60\" max=\"60\" value=\"-20\" class=\"w-full\" data-kid=\"23\">\n            </div>\n\n            <div class=\"space-y-4\" data-kid=\"24\">\n              <div class=\"flex justify-between items-end\" data-kid=\"25\">\n                <label class=\"text-sm font-medium text-slate-300\" data-kid=\"26\">Temperature rise</label>\n                <span class=\"text-cyan-400 font-mono font-bold\" data-kid=\"27\">+2.5 C</span>\n              </div>\n              <input type=\"range\" min=\"-3\" max=\"6\" value=\"2.5\" class=\"w-full\" data-kid=\"28\">\n            </div>\n\n            <div class=\"space-y-4\" data-kid=\"29\">\n              <div class=\"flex justify-between items-end\" data-kid=\"30\">\n                <label class=\"text-sm font-medium text-slate-300\" data-kid=\"31\">Reservoir capacity change</label>\n                <span class=\"text-cyan-400 font-mono font-bold\" data-kid=\"32\">-30%</span>\n              </div>\n              <input type=\"range\" min=\"-70\" max=\"40\" value=\"-30\" class=\"w-full\" data-kid=\"33\">\n            </div>\n\n            <div class=\"space-y-4\" data-kid=\"34\">\n              <div class=\"flex justify-between items-end\" data-kid=\"35\">\n                <label class=\"text-sm font-medium text-slate-300\" data-kid=\"36\">Planning horizon</label>\n                <span class=\"text-cyan-400 font-mono font-bold\" data-kid=\"37\">12 years</span>\n              </div>\n              <input type=\"range\" min=\"1\" max=\"30\" value=\"12\" class=\"w-full\" data-kid=\"38\">\n            </div>\n          </div>\n\n          \n          <div class=\"flex flex-col sm:flex-row gap-4 pt-4\" data-kid=\"39\">\n            <button class=\"flex-1 bg-cyan-500 hover:bg-cyan-600 text-slate-950 font-bold py-3.5 rounded-xl transition-all shadow-[0_0_20px_rgba(6,182,212,0.4)] flex items-center justify-center gap-2\" data-kid=\"40\">\n              <i data-lucide=\"play\" class=\"w-4 h-4 fill-current\" data-kid=\"41\"></i>\n              Run Simulation\n            </button>\n            <button class=\"flex-1 border border-slate-700 hover:bg-slate-800 text-white font-semibold py-3.5 rounded-xl transition-all flex items-center justify-center gap-2\" data-kid=\"42\">\n              <i data-lucide=\"rotate-ccw\" class=\"w-4 h-4\" data-kid=\"43\"></i>\n              Reset\n            </button>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"glass-card rounded-2xl overflow-hidden scanline shadow-2xl\" data-kid=\"44\">\n        <div class=\"p-6 border-b border-cyan-400/10\" data-kid=\"45\">\n          <h2 class=\"text-xl font-bold text-white\" data-kid=\"46\">Projected Impact</h2>\n          <p class=\"text-sm text-slate-400 mt-1\" data-kid=\"47\">Scenario output updates the risk overlay contract used by the map.</p>\n        </div>\n\n        <div class=\"p-8\" data-kid=\"48\">\n          <div class=\"grid grid-cols-1 lg:grid-cols-[1fr_1.2fr] gap-12 items-center\" data-kid=\"49\">\n            \n            \n            <div class=\"flex flex-col items-center justify-center space-y-4\" data-kid=\"50\">\n              <div class=\"relative w-56 h-56 flex items-center justify-center\" data-kid=\"51\">\n                <svg class=\"w-full h-full -rotate-90\" viewBox=\"0 0 100 100\" data-kid=\"52\">\n                  <circle cx=\"50\" cy=\"50\" r=\"42\" fill=\"transparent\" stroke=\"rgba(34, 211, 238, 0.1)\" stroke-width=\"8\" data-kid=\"53\"></circle>\n                  <circle cx=\"50\" cy=\"50\" r=\"42\" fill=\"transparent\" stroke=\"var(--cyan-primary)\" stroke-width=\"8\" stroke-dasharray=\"263.89\" stroke-dashoffset=\"65.97\" stroke-linecap=\"round\" class=\"drop-shadow-[0_0_8px_rgba(6,182,212,0.8)]\" data-kid=\"54\"></circle>\n                </svg>\n                <div class=\"absolute inset-0 flex flex-col items-center justify-center\" data-kid=\"55\">\n                  <span class=\"text-5xl font-black text-white\" data-kid=\"56\">75</span>\n                  <span class=\"text-[10px] uppercase tracking-widest text-cyan-400 font-bold\" data-kid=\"57\">High Risk</span>\n                </div>\n              </div>\n              <p class=\"text-sm font-semibold text-slate-300\" data-kid=\"58\">Composite Climate Risk</p>\n            </div>\n\n            \n            <div class=\"space-y-4\" data-kid=\"59\">\n              <div class=\"glass-card rounded-xl p-4 bg-slate-900/30\" data-kid=\"60\">\n                <div class=\"flex justify-between text-xs font-bold mb-2\" data-kid=\"61\">\n                  <span class=\"text-slate-400 uppercase tracking-tighter\" data-kid=\"62\">Water availability</span>\n                  <span class=\"text-white\" data-kid=\"63\">42%</span>\n                </div>\n                <div class=\"h-2 w-full bg-slate-800 rounded-full overflow-hidden\" data-kid=\"64\">\n                  <div class=\"h-full bg-cyan-400 rounded-full\" style=\"width: 42%\" data-kid=\"65\"></div>\n                </div>\n              </div>\n\n              <div class=\"glass-card rounded-xl p-4 bg-slate-900/30\" data-kid=\"66\">\n                <div class=\"flex justify-between text-xs font-bold mb-2\" data-kid=\"67\">\n                  <span class=\"text-slate-400 uppercase tracking-tighter\" data-kid=\"68\">Crop stress</span>\n                  <span class=\"text-white\" data-kid=\"69\">68%</span>\n                </div>\n                <div class=\"h-2 w-full bg-slate-800 rounded-full overflow-hidden\" data-kid=\"70\">\n                  <div class=\"h-full bg-emerald-400 rounded-full shadow-[0_0_10px_rgba(16,185,129,0.3)]\" style=\"width: 68%\" data-kid=\"71\"></div>\n                </div>\n              </div>\n\n              <div class=\"glass-card rounded-xl p-4 bg-slate-900/30\" data-kid=\"72\">\n                <div class=\"flex justify-between text-xs font-bold mb-2\" data-kid=\"73\">\n                  <span class=\"text-slate-400 uppercase tracking-tighter\" data-kid=\"74\">Drought risk</span>\n                  <span class=\"text-white\" data-kid=\"75\">82%</span>\n                </div>\n                <div class=\"h-2 w-full bg-slate-800 rounded-full overflow-hidden\" data-kid=\"76\">\n                  <div class=\"h-full bg-amber-500 rounded-full shadow-[0_0_10px_rgba(245,158,11,0.3)]\" style=\"width: 82%\" data-kid=\"77\"></div>\n                </div>\n              </div>\n\n              <div class=\"glass-card rounded-xl p-4 bg-slate-900/30\" data-kid=\"78\">\n                <div class=\"flex justify-between text-xs font-bold mb-2\" data-kid=\"79\">\n                  <span class=\"text-slate-400 uppercase tracking-tighter\" data-kid=\"80\">Heatwave risk</span>\n                  <span class=\"text-white\" data-kid=\"81\">55%</span>\n                </div>\n                <div class=\"h-2 w-full bg-slate-800 rounded-full overflow-hidden\" data-kid=\"82\">\n                  <div class=\"h-full bg-rose-500 rounded-full shadow-[0_0_10px_rgba(244,63,94,0.3)]\" style=\"width: 55%\" data-kid=\"83\"></div>\n                </div>\n              </div>\n\n              <div class=\"glass-card rounded-xl p-4 bg-slate-900/30\" data-kid=\"84\">\n                <div class=\"flex justify-between text-xs font-bold mb-2\" data-kid=\"85\">\n                  <span class=\"text-slate-400 uppercase tracking-tighter\" data-kid=\"86\">Flood risk</span>\n                  <span class=\"text-white\" data-kid=\"87\">15%</span>\n                </div>\n                <div class=\"h-2 w-full bg-slate-800 rounded-full overflow-hidden\" data-kid=\"88\">\n                  <div class=\"h-full bg-cyan-400 rounded-full shadow-[0_0_10px_rgba(34,211,238,0.3)]\" style=\"width: 15%\" data-kid=\"89\"></div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</main>\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"90\"></script>\n<script data-kid=\"91\">\n  lucide.createIcons();\n</script>",
