      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n\n  :root {\n    --background: 220 42% 7%;\n    --foreground: 192 35% 96%;\n    --card: 218 36% 10%;\n    --primary: 185 92% 46%;\n    --secondary: 154 68% 42%;\n    --border: 196 42% 22%;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    color: hsl(var(--foreground));\n    margin: 0;\n    min-height: 100vh;\n    background: \n      radial-gradient(circle at 18% 12%, rgba(6, 182, 212, 0.15), transparent 30%),\n      radial-gradient(circle at 82% 16%, rgba(34, 197, 94, 0.12), transparent 28%),\n      linear-gradient(135deg, #04111f 0%, #071829 48%, #06120d 100%);\n  }\n\n  .radar-grid {\n    background-image: \n      linear-gradient(rgba(34, 211, 238, 0.08) 1px, transparent 1px), \n      linear-gradient(90deg, rgba(34, 211, 238, 0.08) 1px, transparent 1px);\n    background-size: 40px 40px;\n  }\n\n  .glass-card {\n    background: rgba(8, 20, 34, 0.7);\n    backdrop-filter: blur(20px);\n    border: 1px solid rgba(125, 211, 252, 0.15);\n    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);\n  }\n\n  .scanline {\n    position: relative;\n    overflow: hidden;\n  }\n\n  .scanline::after {\n    animation: scan 8s linear infinite;\n    background: linear-gradient(180deg, transparent, rgba(34, 211, 238, 0.08), transparent);\n    content: \"\";\n    height: 40%;\n    left: 0;\n    pointer-events: none;\n    position: absolute;\n    top: -40%;\n    width: 100%;\n  }\n\n  @keyframes scan {\n    to { transform: translateY(500%); }\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar { width: 6px; }\n  ::-webkit-scrollbar-track { background: transparent; }\n  ::-webkit-scrollbar-thumb { background: rgba(34, 211, 238, 0.2); border-radius: 10px; }\n</style>\n\n<div class=\"min-h-screen radar-grid p-8 lg:p-12\" data-kid=\"1\">\n  \n  <div class=\"mb-10\" data-kid=\"2\">\n    <div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full border border-cyan-500/30 bg-cyan-500/10 text-cyan-400 text-xs font-semibold tracking-wider uppercase mb-4\" data-kid=\"3\">\n      <i data-lucide=\"shield-check\" class=\"w-3.5 h-3.5\" data-kid=\"4\"></i>\n      Production Validation Layer v1.0.4\n    </div>\n    <h1 class=\"text-4xl lg:text-5xl font-bold tracking-tight text-white flex items-center gap-4\" data-kid=\"5\">\n      Model Performance & Validation\n      <span class=\"text-sm font-normal text-slate-500 bg-slate-800/50 px-3 py-1 rounded border border-slate-700\" data-kid=\"6\">Pilot Region: Kutch, Gujarat</span>\n    </h1>\n    <p class=\"mt-4 text-slate-400 max-w-2xl leading-relaxed\" data-kid=\"7\">\n      Continuous verification of AI forecasting accuracy against ground-truth IMD gridded datasets and satellite observations.\n    </p>\n  </div>\n\n  \n  <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8\" data-kid=\"8\">\n    <div class=\"glass-card p-6 rounded-xl flex flex-col gap-1\" data-kid=\"9\">\n      <span class=\"text-slate-500 text-xs font-medium uppercase tracking-widest\" data-kid=\"10\">Overall Accuracy</span>\n      <div class=\"flex items-end gap-2\" data-kid=\"11\">\n        <span class=\"text-3xl font-bold text-white\" data-kid=\"12\">94.2%</span>\n        <span class=\"text-emerald-400 text-xs font-medium mb-1.5 flex items-center gap-0.5\" data-kid=\"13\">\n          <i data-lucide=\"trending-up\" class=\"w-3 h-3\" data-kid=\"14\"></i> +0.8%\n        </span>\n      </div>\n      <div class=\"w-full bg-slate-800 h-1.5 rounded-full mt-4 overflow-hidden\" data-kid=\"15\">\n        <div class=\"bg-emerald-500 h-full rounded-full\" style=\"width: 94.2%\" data-kid=\"16\"></div>\n      </div>\n    </div>\n    \n    <div class=\"glass-card p-6 rounded-xl flex flex-col gap-1\" data-kid=\"17\">\n      <span class=\"text-slate-500 text-xs font-medium uppercase tracking-widest\" data-kid=\"18\">Total Samples</span>\n      <span class=\"text-3xl font-bold text-white\" data-kid=\"19\">12,840</span>\n      <p class=\"text-xs text-slate-500 mt-2\" data-kid=\"20\">Validated observations (2020-2024)</p>\n    </div>\n\n    <div class=\"glass-card p-6 rounded-xl flex flex-col gap-1\" data-kid=\"21\">\n      <span class=\"text-slate-500 text-xs font-medium uppercase tracking-widest\" data-kid=\"22\">Training Drift</span>\n      <div class=\"flex items-center gap-2\" data-kid=\"23\">\n        <span class=\"text-3xl font-bold text-white\" data-kid=\"24\">0.12</span>\n        <span class=\"text-emerald-400 bg-emerald-400/10 border border-emerald-400/20 px-2 py-0.5 rounded text-[10px] font-bold\" data-kid=\"25\">STABLE</span>\n      </div>\n      <p class=\"text-xs text-slate-500 mt-2\" data-kid=\"26\">Kullback–Leibler divergence score</p>\n    </div>\n\n    <div class=\"glass-card p-6 rounded-xl flex flex-col gap-1\" data-kid=\"27\">\n      <span class=\"text-slate-500 text-xs font-medium uppercase tracking-widest\" data-kid=\"28\">Model Latency</span>\n      <span class=\"text-3xl font-bold text-white\" data-kid=\"29\">240ms</span>\n      <p class=\"text-xs text-slate-500 mt-2\" data-kid=\"30\">Inference time per district profile</p>\n    </div>\n  </div>\n\n  <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-8\" data-kid=\"31\">\n    \n    <div class=\"lg:col-span-8 flex flex-col gap-8\" data-kid=\"32\">\n      \n      \n      <div class=\"glass-card rounded-2xl p-8 scanline\" data-kid=\"33\">\n        <div class=\"flex justify-between items-start mb-8\" data-kid=\"34\">\n          <div data-kid=\"35\">\n            <h3 class=\"text-xl font-bold text-white flex items-center gap-2\" data-kid=\"36\">\n              <i data-lucide=\"cloud-rain\" class=\"w-5 h-5 text-cyan-400\" data-kid=\"37\"></i>\n              Rainfall: Actual vs Predicted\n            </h3>\n            <p class=\"text-sm text-slate-500 mt-1\" data-kid=\"38\">IMD Gridded (0.25° x 0.25°) vs LSTM-Transformer Hybrid</p>\n          </div>\n          <div class=\"flex gap-4\" data-kid=\"39\">\n            <div class=\"flex items-center gap-2 text-xs font-medium text-slate-400\" data-kid=\"40\">\n              <span class=\"w-3 h-3 rounded-full bg-cyan-400 shadow-[0_0_8px_rgba(6,182,212,0.5)]\" data-kid=\"41\"></span> Actual\n            </div>\n            <div class=\"flex items-center gap-2 text-xs font-medium text-slate-400\" data-kid=\"42\">\n              <span class=\"w-3 h-3 rounded-full border border-slate-500 border-dashed\" data-kid=\"43\"></span> Predicted\n            </div>\n          </div>\n        </div>\n        <div class=\"h-[360px] w-full relative\" data-kid=\"44\">\n          <canvas id=\"rainfallChart\" data-kid=\"45\"></canvas>\n        </div>\n      </div>\n\n      \n      <div class=\"glass-card rounded-2xl p-8\" data-kid=\"46\">\n        <div class=\"flex justify-between items-start mb-8\" data-kid=\"47\">\n          <div data-kid=\"48\">\n            <h3 class=\"text-xl font-bold text-white flex items-center gap-2\" data-kid=\"49\">\n              <i data-lucide=\"thermometer\" class=\"w-5 h-5 text-rose-400\" data-kid=\"50\"></i>\n              Temperature: Actual vs Predicted\n            </h3>\n            <p class=\"text-sm text-slate-500 mt-1\" data-kid=\"51\">Daily Max/Min Observations vs CNN-LSTM Fusion</p>\n          </div>\n          <div class=\"flex gap-4\" data-kid=\"52\">\n            <div class=\"flex items-center gap-2 text-xs font-medium text-slate-400\" data-kid=\"53\">\n              <span class=\"w-3 h-3 rounded-full bg-rose-500 shadow-[0_0_8px_rgba(244,63,94,0.5)]\" data-kid=\"54\"></span> Actual\n            </div>\n            <div class=\"flex items-center gap-2 text-xs font-medium text-slate-400\" data-kid=\"55\">\n              <span class=\"w-3 h-3 rounded-full bg-rose-400/30 border border-rose-400/50\" data-kid=\"56\"></span> Predicted\n            </div>\n          </div>\n        </div>\n        <div class=\"h-[360px] w-full relative\" data-kid=\"57\">\n          <canvas id=\"tempChart\" data-kid=\"58\"></canvas>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"lg:col-span-4 flex flex-col gap-8\" data-kid=\"59\">\n      \n      \n      <div class=\"glass-card rounded-2xl p-6\" data-kid=\"60\">\n        <h3 class=\"text-lg font-bold text-white mb-6 flex items-center gap-2\" data-kid=\"61\">\n          <i data-lucide=\"bar-chart-big\" class=\"w-5 h-5 text-emerald-400\" data-kid=\"62\"></i>\n          Performance Metrics\n        </h3>\n        <div class=\"space-y-6\" data-kid=\"63\">\n          \n          <div data-kid=\"64\">\n            <div class=\"flex justify-between items-center mb-4\" data-kid=\"65\">\n              <span class=\"text-sm font-semibold text-slate-300\" data-kid=\"66\">LSTM-Transformer (Rainfall)</span>\n              <span class=\"text-[10px] bg-cyan-500/10 text-cyan-400 px-2 py-0.5 rounded border border-cyan-500/20\" data-kid=\"67\">ACTIVE</span>\n            </div>\n            <div class=\"grid grid-cols-3 gap-3\" data-kid=\"68\">\n              <div class=\"bg-slate-900/50 border border-slate-800 p-3 rounded-lg text-center\" data-kid=\"69\">\n                <div class=\"text-[10px] text-slate-500 font-bold uppercase mb-1\" data-kid=\"70\">RMSE</div>\n                <div class=\"text-sm font-bold text-white\" data-kid=\"71\">4.12</div>\n              </div>\n              <div class=\"bg-slate-900/50 border border-slate-800 p-3 rounded-lg text-center\" data-kid=\"72\">\n                <div class=\"text-[10px] text-slate-500 font-bold uppercase mb-1\" data-kid=\"73\">MAE</div>\n                <div class=\"text-sm font-bold text-white\" data-kid=\"74\">2.84</div>\n              </div>\n              <div class=\"bg-slate-900/50 border border-slate-800 p-3 rounded-lg text-center\" data-kid=\"75\">\n                <div class=\"text-[10px] text-slate-500 font-bold uppercase mb-1\" data-kid=\"76\">R²</div>\n                <div class=\"text-sm font-bold text-emerald-400\" data-kid=\"77\">0.92</div>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"h-px bg-slate-800\" data-kid=\"78\"></div>\n\n          \n          <div data-kid=\"79\">\n            <div class=\"flex justify-between items-center mb-4\" data-kid=\"80\">\n              <span class=\"text-sm font-semibold text-slate-300\" data-kid=\"81\">CNN-LSTM (Temperature)</span>\n              <span class=\"text-[10px] bg-slate-700 text-slate-400 px-2 py-0.5 rounded border border-slate-600 uppercase\" data-kid=\"82\">Production</span>\n            </div>\n            <div class=\"grid grid-cols-3 gap-3\" data-kid=\"83\">\n              <div class=\"bg-slate-900/50 border border-slate-800 p-3 rounded-lg text-center\" data-kid=\"84\">\n                <div class=\"text-[10px] text-slate-500 font-bold uppercase mb-1\" data-kid=\"85\">RMSE</div>\n                <div class=\"text-sm font-bold text-white\" data-kid=\"86\">0.85</div>\n              </div>\n              <div class=\"bg-slate-900/50 border border-slate-800 p-3 rounded-lg text-center\" data-kid=\"87\">\n                <div class=\"text-[10px] text-slate-500 font-bold uppercase mb-1\" data-kid=\"88\">MAE</div>\n                <div class=\"text-sm font-bold text-white\" data-kid=\"89\">0.62</div>\n              </div>\n              <div class=\"bg-slate-900/50 border border-slate-800 p-3 rounded-lg text-center\" data-kid=\"90\">\n                <div class=\"text-[10px] text-slate-500 font-bold uppercase mb-1\" data-kid=\"91\">R²</div>\n                <div class=\"text-sm font-bold text-emerald-400\" data-kid=\"92\">0.96</div>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"h-px bg-slate-800\" data-kid=\"93\"></div>\n\n          \n          <div data-kid=\"94\">\n            <div class=\"flex justify-between items-center mb-4\" data-kid=\"95\">\n              <span class=\"text-sm font-semibold text-slate-300\" data-kid=\"96\">Baseline Random Forest</span>\n              <span class=\"text-[10px] bg-slate-800 text-slate-500 px-2 py-0.5 rounded border border-slate-700 uppercase tracking-tighter\" data-kid=\"97\">Comparison</span>\n            </div>\n            <div class=\"grid grid-cols-3 gap-3 opacity-60\" data-kid=\"98\">\n              <div class=\"bg-slate-900/50 border border-slate-800 p-3 rounded-lg text-center\" data-kid=\"99\">\n                <div class=\"text-[10px] text-slate-500 font-bold uppercase mb-1\" data-kid=\"100\">RMSE</div>\n                <div class=\"text-sm font-bold text-white\" data-kid=\"101\">6.24</div>\n              </div>\n              <div class=\"bg-slate-900/50 border border-slate-800 p-3 rounded-lg text-center\" data-kid=\"102\">\n                <div class=\"text-[10px] text-slate-500 font-bold uppercase mb-1\" data-kid=\"103\">MAE</div>\n                <div class=\"text-sm font-bold text-white\" data-kid=\"104\">4.15</div>\n              </div>\n              <div class=\"bg-slate-900/50 border border-slate-800 p-3 rounded-lg text-center\" data-kid=\"105\">\n                <div class=\"text-[10px] text-slate-500 font-bold uppercase mb-1\" data-kid=\"106\">R²</div>\n                <div class=\"text-sm font-bold text-white\" data-kid=\"107\">0.78</div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"glass-card rounded-2xl p-6\" data-kid=\"108\">\n        <h3 class=\"text-lg font-bold text-white mb-6 flex items-center gap-2\" data-kid=\"109\">\n          <i data-lucide=\"binary\" class=\"w-5 h-5 text-cyan-400\" data-kid=\"110\"></i>\n          Training Metadata\n        </h3>\n        <div class=\"space-y-4\" data-kid=\"111\">\n          <div class=\"flex justify-between text-sm py-2 border-b border-slate-800\" data-kid=\"112\">\n            <span class=\"text-slate-500\" data-kid=\"113\">Epochs</span>\n            <span class=\"text-white font-mono\" data-kid=\"114\">1,500</span>\n          </div>\n          <div class=\"flex justify-between text-sm py-2 border-b border-slate-800\" data-kid=\"115\">\n            <span class=\"text-slate-500\" data-kid=\"116\">Validation Split</span>\n            <span class=\"text-white font-mono\" data-kid=\"117\">20.0%</span>\n          </div>\n          <div class=\"flex justify-between text-sm py-2 border-b border-slate-800\" data-kid=\"118\">\n            <span class=\"text-slate-500\" data-kid=\"119\">Learning Rate</span>\n            <span class=\"text-white font-mono\" data-kid=\"120\">0.0001</span>\n          </div>\n          <div class=\"flex justify-between text-sm py-2 border-b border-slate-800\" data-kid=\"121\">\n            <span class=\"text-slate-500\" data-kid=\"122\">Optimizer</span>\n            <span class=\"text-white font-mono\" data-kid=\"123\">AdamW</span>\n          </div>\n          <div class=\"flex justify-between text-sm py-2\" data-kid=\"124\">\n            <span class=\"text-slate-500\" data-kid=\"125\">Dataset Version</span>\n            <span class=\"text-white font-mono\" data-kid=\"126\">v4.2.0-PROD</span>\n          </div>\n        </div>\n        <button class=\"w-full mt-6 bg-slate-800 hover:bg-slate-700 text-white text-xs font-bold py-3 rounded-lg border border-slate-700 transition-all uppercase tracking-widest flex items-center justify-center gap-2\" data-kid=\"127\">\n          <i data-lucide=\"refresh-cw\" class=\"w-3.5 h-3.5\" data-kid=\"128\"></i>\n          Retrain Model\n        </button>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"129\"></script>\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"130\"></script>\n<script data-kid=\"131\">\n  lucide.createIcons();\n\n  const labels = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];\n  \n  // Rainfall Data\n  const rainfallActual = [12, 19, 45, 60, 110, 320, 410, 380, 240, 95, 20, 10];\n  const rainfallPred = [10, 22, 48, 55, 120, 310, 395, 390, 250, 90, 25, 12];\n\n  // Temp Data\n  const tempActual = [28, 32, 36, 41, 44, 42, 38, 36, 35, 33, 30, 28];\n  const tempPred = [27.5, 32.2, 35.8, 40.5, 43.8, 41.5, 38.2, 36.5, 34.8, 33.2, 29.8, 27.8];\n\n  const chartOptions = {\n    responsive: true,\n    maintainAspectRatio: false,\n    plugins: {\n      legend: { display: false }\n    },\n    scales: {\n      y: {\n        grid: { color: 'rgba(255, 255, 255, 0.05)' },\n        ticks: { color: '#64748b', font: { size: 10 } }\n      },\n      x: {\n        grid: { display: false },\n        ticks: { color: '#64748b', font: { size: 10 } }\n      }\n    },\n    elements: {\n      line: { tension: 0.4 },\n      point: { radius: 3, hoverRadius: 5 }\n    }\n  };\n\n  new Chart(document.getElementById('rainfallChart'), {\n    type: 'line',\n    data: {\n      labels: labels,\n      datasets: [\n        {\n          label: 'Actual',\n          data: rainfallActual,\n          borderColor: '#06b6d4',\n          backgroundColor: 'rgba(6, 182, 212, 0.1)',\n          fill: true,\n          borderWidth: 3,\n        },\n        {\n          label: 'Predicted',\n          data: rainfallPred,\n          borderColor: 'rgba(148, 163, 184, 0.5)',\n          borderDash: [5, 5],\n          borderWidth: 2,\n          pointStyle: 'circle'\n        }\n      ]\n    },\n    options: chartOptions\n  });\n\n  new Chart(document.getElementById('tempChart'), {\n    type: 'line',\n    data: {\n      labels: labels,\n      datasets: [\n        {\n          label: 'Actual',\n          data: tempActual,\n          borderColor: '#f43f5e',\n          backgroundColor: 'rgba(244, 63, 94, 0.1)',\n          fill: true,\n          borderWidth: 3,\n        },\n        {\n          label: 'Predicted',\n          data: tempPred,\n          borderColor: 'rgba(251, 113, 133, 0.4)',\n          borderWidth: 2,\n          pointStyle: 'rect'\n        }\n      ]\n    },\n    options: chartOptions\n  });\n</script>",
